# Production/staging renderer environment.
# NODE_ENV, HOST, and PORT are set by apps/renderer/compose.yml.

SIAB_CMS_URL=https://admin.siteinabox.nl
SIAB_RENDERER_API_TOKEN=<same value configured in CMS>

# Astro canonical origin default for the temporary staging deployment.
SITE_URL=https://amicare.optidigi.nl

# Keep empty in production.
SIAB_RENDERER_FIXTURE_MODE=
