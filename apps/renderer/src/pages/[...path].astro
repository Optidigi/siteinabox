---
import { renderToStaticMarkup } from "react-dom/server"
import { getRendererDeployTargetByHost, isRendererProductionHost } from "@siteinabox/contracts/deploy-targets"
import { SitePageRenderer, buildPageSeoMetadata, createRendererMediaResolver, resolveLegacyTenant } from "@siteinabox/site-renderer"
import "../styles/site.css"
import { analyticsConfigJson, buildAnalyticsConfig } from "../lib/analytics-config.js"
import { normalizeRequestHost, resolvePublishedPage } from "../lib/snapshot"
import * as amicareLegacy from "../lib/legacy-tenants/amicare/legacy-response"

const pathname = `/${Astro.params.path ?? ""}`
const host = normalizeRequestHost(Astro.request.headers.get("x-forwarded-host") ?? Astro.request.headers.get("host"))
const liveDeployTarget = getRendererDeployTargetByHost(host)

const liveLegacyAssetResponse = async () => {
  if (!liveDeployTarget?.legacyAssetPrefixes.some((prefix) => pathname.startsWith(prefix))) return null

  if (liveDeployTarget.id === "ami-care") {
    return amicareLegacy.createAmicareLegacyResponse(pathname)
  }
  return null
}

if (!isRendererProductionHost(host) && amicareLegacy.isAmicareLegacyHost(host)) {
  return await amicareLegacy.createAmicareLegacyResponseOrNotFound(pathname)
}

const legacyAssetResponse = await liveLegacyAssetResponse()
if (legacyAssetResponse) return legacyAssetResponse

const resolved = await resolvePublishedPage(pathname, host)

if (!resolved) {
  Astro.response.status = 404
}

const seo = resolved
  ? buildPageSeoMetadata({
      page: resolved.page,
      settings: resolved.snapshot.settings,
      mediaResolver: createRendererMediaResolver(resolved.snapshot.tenantId),
    })
  : null
const mediaResolver = resolved ? createRendererMediaResolver(resolved.snapshot.tenantId) : undefined
const rendererHtml = resolved
  ? renderToStaticMarkup(
      SitePageRenderer({
        page: resolved.page,
        settings: resolved.snapshot.settings,
        theme: resolved.snapshot.theme,
        tenantSlug: resolved.snapshot.tenantSlug,
        domain: resolved.snapshot.domain,
        mediaResolver,
      }),
    )
  : ""
const analyticsJson =
  resolved ? analyticsConfigJson(buildAnalyticsConfig({ snapshot: resolved.snapshot, page: resolved.page, pathname: resolved.pathname })) : null
const legacyTenant = resolved
  ? resolveLegacyTenant({
      tenantSlug: resolved.snapshot.tenantSlug,
      domain: resolved.snapshot.domain,
      settings: resolved.snapshot.settings,
    })
  : null
const mediaHref = (value: unknown): string | null => {
  if (!value || !mediaResolver) return null
  const resolvedMedia = mediaResolver(value)
  if (!resolvedMedia) return null
  if (typeof resolvedMedia === "string") return resolvedMedia
  if (resolvedMedia.src) return resolvedMedia.src
  return null
}
const faviconHref =
  resolved
    ? mediaHref(resolved.snapshot.settings.branding?.favicon) ??
      (legacyTenant === "amicare" ? "/favicon.svg" : null)
    : null
const appleTouchIconHref = legacyTenant ? "/apple-touch-icon.png" : null
const manifestHref = legacyTenant ? "/manifest.json" : null
const sitemapHref = legacyTenant ? "/sitemap-index.xml" : null
const showRendererCookieConsent = Boolean(analyticsJson && legacyTenant !== "amicare")
const rendererCookieConsentScript = `(() => {
  const preferenceKey = "siab_cookie_consent_v1";
  const banner = document.getElementById("renderer-cookie-consent-banner");
  const preferences = document.getElementById("renderer-cookie-consent-preferences");
  if (!banner || !preferences) return;
  const readPreference = () => {
    try { return window.localStorage.getItem(preferenceKey); } catch { return null; }
  };
  const writePreference = (value) => {
    try { window.localStorage.setItem(preferenceKey, value); } catch {}
  };
  const showBanner = () => {
    banner.classList.remove("hidden");
    preferences.classList.add("hidden");
  };
  const hideBanner = () => {
    banner.classList.add("hidden");
    preferences.classList.remove("hidden");
  };
  const applyPreference = (value) => {
    if (value === "accepted") {
      window.SIABAnalytics?.grantConsent();
      hideBanner();
      return;
    }
    if (value === "declined") {
      window.SIABAnalytics?.revokeConsent();
      hideBanner();
      return;
    }
    showBanner();
  };
  banner.querySelector("[data-cookie-consent-accept]")?.addEventListener("click", () => {
    writePreference("accepted");
    applyPreference("accepted");
  });
  banner.querySelector("[data-cookie-consent-decline]")?.addEventListener("click", () => {
    writePreference("declined");
    applyPreference("declined");
  });
  preferences.addEventListener("click", showBanner);
  applyPreference(readPreference());
})();`
---

<!doctype html>
{
  resolved && seo ? (
    <html lang={resolved.snapshot.settings.language} data-renderer-schema={resolved.snapshot.schemaVersion}>
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <style is:global>
          html,
          body {
            margin: 0;
            min-width: 320px;
          }
        </style>
        {faviconHref && <link rel="icon" href={faviconHref} />}
        {appleTouchIconHref && <link rel="apple-touch-icon" href={appleTouchIconHref} />}
        {manifestHref && <link rel="manifest" href={manifestHref} />}
        {sitemapHref && <link rel="sitemap" href={sitemapHref} />}
        <title>{seo.title}</title>
        {seo.description && <meta name="description" content={seo.description} />}
        {seo.canonical && <link rel="canonical" href={seo.canonical} />}
        <meta property="og:site_name" content={resolved.snapshot.settings.siteName} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={seo.openGraph?.title ?? seo.title} />
        {seo.openGraph?.description && <meta property="og:description" content={seo.openGraph.description} />}
        {seo.openGraph?.url && <meta property="og:url" content={seo.openGraph.url} />}
        {seo.openGraph?.images?.map((image) => (
          <>
            <meta property="og:image" content={image.url} />
            {image.alt && <meta property="og:image:alt" content={image.alt} />}
          </>
        ))}
        <meta name="twitter:card" content={seo.openGraph?.images?.length ? "summary_large_image" : "summary"} />
      </head>
      <body data-tenant-slug={resolved.snapshot.tenantSlug}>
        <div set:html={rendererHtml} />
        {analyticsJson && <script is:inline id="siab-analytics-config" type="application/json" set:html={analyticsJson} />}
        {showRendererCookieConsent && (
          <>
            <div
              id="renderer-cookie-consent-banner"
              class="fixed inset-x-4 bottom-4 z-[80] hidden max-w-xl rounded-lg border border-black/10 bg-white p-4 text-slate-900 shadow-2xl sm:left-6 sm:right-auto"
              role="dialog"
              aria-live="polite"
              aria-label="Cookie voorkeuren"
            >
              <div class="space-y-4">
                <div class="space-y-2">
                  <p class="text-lg font-semibold leading-tight">Cookies</p>
                  <p class="text-sm leading-6 text-slate-600">
                    We gebruiken noodzakelijke cookies voor de website. Met uw toestemming meten we hoe de website wordt gebruikt.
                  </p>
                </div>
                <div class="flex flex-col gap-2 sm:flex-row">
                  <button type="button" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white" data-cookie-consent-accept>
                    Accepteren
                  </button>
                  <button type="button" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900" data-cookie-consent-decline>
                    Weigeren
                  </button>
                </div>
              </div>
            </div>
            <button
              id="renderer-cookie-consent-preferences"
              type="button"
              class="fixed bottom-4 right-4 z-[70] hidden rounded-md border border-black/10 bg-white px-3 py-2 text-xs font-medium text-slate-600 shadow-lg"
            >
              Cookies
            </button>
            <script is:inline set:html={rendererCookieConsentScript} />
          </>
        )}
        <script>
          import "../client/site-behavior"
        </script>
      </body>
    </html>
  ) : (
    <html lang="en">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex" />
        <title>Page not found</title>
      </head>
      <body>
        <main class="renderer-not-found">
          <p>404</p>
          <h1>Page not found</h1>
          <a href="/">Return home</a>
        </main>
      </body>
    </html>
  )
}
