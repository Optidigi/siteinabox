---
import { createElement } from "react"
import { renderToStaticMarkup } from "react-dom/server"
import {
  SitePageRenderer,
  buildPageSeoMetadata,
  COLOR_MODE_BOOTSTRAP_SCRIPT,
  createRendererMediaResolver,
  DEFAULT_PROVIDER_NOT_FOUND_TEMPLATE_ID,
  getProviderSystemTemplateRenderer,
  themeMode,
  themePreference,
} from "@siteinabox/site-renderer"
import "../styles/site.css"
import { findPublishedPage, loadPublishedSnapshot, normalizeRequestHost, pagePath } from "../lib/snapshot"
import { analyticsConfigJson, buildAnalyticsConfig } from "../lib/analytics-config.js"

const pathname = `/${Astro.params.path ?? ""}`
const host = normalizeRequestHost(Astro.request.headers.get("x-forwarded-host") ?? Astro.request.headers.get("host"))

const snapshot = await loadPublishedSnapshot(host)
const page = snapshot ? findPublishedPage(snapshot, pathname) : null
const resolved = snapshot && page
  ? {
      snapshot,
      page,
      pathname: pagePath(page),
    }
  : null
const notFoundTemplateId = snapshot?.settings.systemTemplates?.notFound?.variant ?? DEFAULT_PROVIDER_NOT_FOUND_TEMPLATE_ID
const SystemNotFoundTemplate = snapshot && !page
  ? getProviderSystemTemplateRenderer("notFound", notFoundTemplateId)
  : null

if (snapshot && !page && !SystemNotFoundTemplate) {
  throw new Error(`Unresolved provider system template "${notFoundTemplateId}" for notFound.`)
}

if (!resolved) {
  Astro.response.status = 404
}

const seo = resolved
  ? buildPageSeoMetadata({
      page: resolved.page,
      settings: resolved.snapshot.settings,
      mediaResolver: createRendererMediaResolver(resolved.snapshot.tenantId),
    })
  : null
const mediaResolver = resolved ? createRendererMediaResolver(resolved.snapshot.tenantId) : undefined
const analyticsConfig = resolved
  ? buildAnalyticsConfig({ snapshot: resolved.snapshot, page: resolved.page, pathname: resolved.pathname })
  : null
const analyticsConfigContent = analyticsConfigJson(analyticsConfig)
const rendererHtml = resolved
  ? renderToStaticMarkup(
      SitePageRenderer({
        page: resolved.page,
        settings: resolved.snapshot.settings,
        theme: resolved.snapshot.theme,
        tenantSlug: resolved.snapshot.tenantSlug,
        domain: resolved.snapshot.domain,
        mediaResolver,
      }),
    )
  : SystemNotFoundTemplate && snapshot
    ? renderToStaticMarkup(
        createElement(SystemNotFoundTemplate, {
          settings: snapshot.settings,
          theme: snapshot.theme,
          tenantSlug: snapshot.tenantSlug,
          domain: snapshot.domain,
          mediaResolver: createRendererMediaResolver(snapshot.tenantId),
          pathname,
        }),
      )
  : ""
const mediaHref = (value: unknown): string | null => {
  if (!value || !mediaResolver) return null
  const resolvedMedia = mediaResolver(value)
  if (!resolvedMedia) return null
  if (typeof resolvedMedia === "string") return resolvedMedia
  if (resolvedMedia.src) return resolvedMedia.src
  return null
}
const faviconHref =
  resolved
    ? mediaHref(resolved.snapshot.settings.branding?.favicon)
    : null
const configuredThemeMode = themePreference(snapshot?.theme)
const initialColorMode = themeMode(snapshot?.theme)
---

<!doctype html>
{
  resolved && seo ? (
    <html lang={resolved.snapshot.settings.language} data-renderer-schema={resolved.snapshot.schemaVersion} data-siab-theme-mode={configuredThemeMode} data-siab-color-mode={initialColorMode} data-rt-mode={initialColorMode}>
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light dark" />
        <script is:inline set:html={COLOR_MODE_BOOTSTRAP_SCRIPT} />
        <meta name="generator" content={Astro.generator} />
        <style is:global>
          html,
          body {
            margin: 0;
            min-width: 320px;
          }
        </style>
        {faviconHref && <link rel="icon" href={faviconHref} />}
        <title>{seo.title}</title>
        {seo.description && <meta name="description" content={seo.description} />}
        {seo.canonical && <link rel="canonical" href={seo.canonical} />}
        <meta property="og:site_name" content={resolved.snapshot.settings.siteName} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={seo.openGraph?.title ?? seo.title} />
        {seo.openGraph?.description && <meta property="og:description" content={seo.openGraph.description} />}
        {seo.openGraph?.url && <meta property="og:url" content={seo.openGraph.url} />}
        {seo.openGraph?.images?.map((image) => (
          <>
            <meta property="og:image" content={image.url} />
            {image.alt && <meta property="og:image:alt" content={image.alt} />}
          </>
        ))}
        <meta name="twitter:card" content={seo.openGraph?.images?.length ? "summary_large_image" : "summary"} />
      </head>
      <body data-tenant-slug={resolved.snapshot.tenantSlug}>
        {analyticsConfigContent && <script is:inline id="siab-analytics-config" type="application/json" set:html={analyticsConfigContent} />}
        <div set:html={rendererHtml} />
        <script>
          import "../client/site-behavior"
        </script>
      </body>
    </html>
  ) : SystemNotFoundTemplate && snapshot ? (
    <html lang={snapshot.settings.language} data-renderer-schema={snapshot.schemaVersion} data-siab-theme-mode={configuredThemeMode} data-siab-color-mode={initialColorMode} data-rt-mode={initialColorMode}>
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light dark" />
        <script is:inline set:html={COLOR_MODE_BOOTSTRAP_SCRIPT} />
        <meta name="generator" content={Astro.generator} />
        <meta name="robots" content="noindex" />
        <style is:global>
          html,
          body {
            margin: 0;
            min-width: 320px;
          }
        </style>
        <title>Page not found | {snapshot.settings.siteName}</title>
      </head>
      <body data-tenant-slug={snapshot.tenantSlug}>
        <div set:html={rendererHtml} />
        <script>
          import "../client/site-behavior"
        </script>
      </body>
    </html>
  ) : (
    <html lang="en">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex" />
        <title>Page not found</title>
      </head>
      <body>
        <main class="renderer-not-found">
          <p>404</p>
          <h1>Page not found</h1>
          <a href="/">Return home</a>
        </main>
      </body>
    </html>
  )
}
