# Postgres
POSTGRES_PASSWORD=change-me
DATABASE_URI=postgres://payload:change-me@localhost:5432/payload

# Payload
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32

# Better Auth social login (OBS-101)
# BETTER_AUTH_SECRET may be omitted to reuse PAYLOAD_SECRET, but a dedicated
# high-entropy value is preferred in production.
BETTER_AUTH_SECRET=
# Optional dedicated secret for isolated customer-preview Better Auth sessions.
# Falls back to BETTER_AUTH_SECRET/PAYLOAD_SECRET when unset.
BETTER_AUTH_PREVIEW_SECRET=
# Optional canonical Better Auth origin. When unset, Better Auth uses SITE_URL
# as the production fallback so magic links do not resolve to localhost/internal
# container hosts.
BETTER_AUTH_URL=
# Optional comma-separated extra hosts allowed for Better Auth callbacks.
# Normal tenant admin hosts are resolved dynamically from Payload tenants.domain.
# Customer preview auth uses a separate /api/preview-auth route and allows
# preview.siteinabox.nl by default.
# Use this only for additional CMS auth hosts that must accept callbacks.
BETTER_AUTH_ALLOWED_HOSTS=
# Optional Better Auth Infrastructure dashboard/audit bridge. Use the API key
# from the existing SIAB project in the Better Auth dashboard. Leave blank to
# keep Infrastructure disabled. Transactional email/SMS and Sentinel are paid
# surfaces and are not enabled by this app yet.
BETTER_AUTH_API_KEY=
BETTER_AUTH_API_URL=
BETTER_AUTH_KV_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# App
DATA_DIR=./.data-out
NEXT_PUBLIC_SUPER_ADMIN_DOMAIN=siteinabox.nl
NODE_ENV=development
# Comma-separated hostnames allowed to load Next dev resources when testing
# super-admin host routing locally, e.g. via Playwright host-resolver rules.
SIAB_ALLOWED_DEV_ORIGINS=admin.siteinabox.nl
# Shared bearer used only by the status Worker to read the active tenant inventory.
STATUS_MONITOR_INVENTORY_TOKEN=

# Email (Cloudflare Email Service)
# Runtime delivery prefers REST API when CLOUDFLARE_ACCOUNT_ID and
# CLOUDFLARE_API_TOKEN are set. SMTP token is an optional fallback for
# environments where outbound smtps://smtp.mx.cloudflare.net:465 is reachable.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL_SMTP_TOKEN=
EMAIL_FROM=noreply@siteinabox.nl
# Dedicated HMAC secret for opaque unsubscribe/preference links.
SIAB_EMAIL_PREFERENCE_SECRET=

# Public abuse limits ---------------------------------------------------
# Anonymous public POST limiter for /api/forms, /api/intake, forgot-password.
SIAB_PUBLIC_POST_RATE_LIMIT_POINTS=10
SIAB_PUBLIC_POST_RATE_LIMIT_WINDOW_SECONDS=60
# Additional generated-site forms limiter keyed by tenant/form target.
SIAB_FORM_TARGET_RATE_LIMIT_POINTS=50
SIAB_FORM_TARGET_RATE_LIMIT_WINDOW_SECONDS=3600

# Legal release synchronization ----------------------------------------
# Production boot verifies the immutable landing manifest before activating
# reviewed legal releases. The Git SHA is recorded as publication evidence.
SIAB_LEGAL_MANIFEST_URL=https://www.siteinabox.nl/.well-known/siab-legal-manifest.json
SIAB_GIT_SHA=

# Mollie payments -------------------------------------------------------
# Use a test key locally/staging and a live key only in production secrets.
# Never commit real API keys or webhook secrets.
MOLLIE_API_KEY=
# Gross customer-facing amounts, including VAT where applicable.
MOLLIE_SITE_PAYMENT_AMOUNT=228.00
MOLLIE_SITE_PAYMENT_CURRENCY=EUR
MOLLIE_SITE_RENEWAL_AMOUNT=19.00
MOLLIE_SITE_RENEWAL_CURRENCY=EUR
MOLLIE_SITE_SUBSCRIPTION_INTERVAL=1 month
# Optional public CMS origin for Mollie webhook callbacks. Falls back to SITE_URL.
MOLLIE_WEBHOOK_BASE_URL=
# Optional defense-in-depth HMAC secret for deployments/proxies that attach
# X-Mollie-Signature. Leave blank when using Mollie's classic payment webhook.
MOLLIE_WEBHOOK_SIGNING_SECRET=

# Domain registration and DNS automation --------------------------------
# OpenProvider checks availability before checkout and registers only after
# Mollie confirms payment. Keep real credentials in deployment secrets.
OPENPROVIDER_USERNAME=
OPENPROVIDER_PASSWORD=
OPENPROVIDER_API_BASE_URL=
# Owner/admin handles are created per customer from checkout holder details.
# Static platform handles are only for SIAB-operated technical/billing contact.
OPENPROVIDER_TECH_HANDLE=
OPENPROVIDER_BILLING_HANDLE=
OPENPROVIDER_DOMAIN_MAX_COST_AMOUNT=7.00
OPENPROVIDER_DOMAIN_MAX_COST_CURRENCY=EUR
# Optional fallback when Cloudflare-created nameservers are not passed to
# registration. Normally checkout automation uses Cloudflare nameservers.
OPENPROVIDER_NS_GROUP=
OPENPROVIDER_NAMESERVERS=

# Cloudflare creates the customer zone and proxied DNS records after payment.
CLOUDFLARE_API_BASE_URL=
# Set one target. Prefer host/CNAME when the renderer sits behind a stable
# platform hostname; use IP/A when the renderer is reached directly.
SIAB_RENDERER_TARGET_HOST=
SIAB_RENDERER_TARGET_IP=

# KVK intake lookup -----------------------------------------------------
# Used only by CMS-owned /api/intake/kvk/* endpoints. Keep the real API key in
# server-side deployment secrets.
KVK_API_KEY=
# Optional root base URL, for example https://api.kvk.nl/test.
KVK_API_BASE_URL=
# Optional full endpoint overrides.
KVK_SEARCH_BASE_URL=
KVK_PROFILE_BASE_URL=

# PostHog analytics (OBS-99) -------------------------------------------
# One shared SIAB PostHog project. Public website tracking is still
# consent-gated by the generated-site runtime. Leave POSTHOG_PROJECT_TOKEN
# empty locally to keep capture disabled.
POSTHOG_ANALYTICS_DISABLED=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PUBLIC_HOST=https://r.siteinabox.nl
POSTHOG_PROJECT_TOKEN=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
# Optional. Use only when the PostHog project API requires the
# organization-scoped project endpoint.
POSTHOG_ORGANIZATION_ID=
POSTHOG_ENVIRONMENT=development

# VPS public IP (used by onboarding checklist for DNS A record)
NEXT_PUBLIC_VPS_IP=192.0.2.1

# Playwright E2E (Phase 17)
E2E_BASE_URL=http://localhost:3001

# Bootstrap (audit-p1 #6) ----------------------------------------------
# Required ONLY during the very first super-admin seed on a fresh DB.
# Set to an `openssl rand -hex 32`-style high-entropy string before
# running the curl in deploy.md Step 8. Then unset it and redeploy —
# leaving it set in production keeps an unauthenticated escalation path
# armed if the users table is ever emptied.
BOOTSTRAP_TOKEN=

# Legacy/internal preview tokens --------------------------------------
# HMAC secret used only for the internal /preview/[token] compatibility
# route. Customer preview access is Better Auth magic-link/session gated
# through https://preview.siteinabox.nl/{clientSlug}.
PREVIEW_HMAC_SECRET=
# Production disables /preview/[token] unless this is exactly "1". This is only
# for temporary internal compatibility; customer previews use Better Auth at
# preview.siteinabox.nl/<clientSlug>.
ENABLE_LEGACY_PREVIEW_TOKEN_ROUTE=

# GraphQL playground (audit-p3 #16) ------------------------------------
# Defense-in-depth env-gate on /api/graphql-playground. In production the
# playground returns 404 unless this is set to the literal string "1".
# Strict equality — "true", "yes", "on", etc. all keep it disabled.
# Leave unset in production. Set to "1" temporarily ONLY while actively
# debugging GraphQL against prod, then unset and redeploy. The Payload
# default `disablePlaygroundInProduction` already returns 404 in prod;
# this gate is the in-repo belt-and-braces against a future config flip.
ENABLE_GRAPHQL_PLAYGROUND=

# ──────────────────────────────────────────────────────────────────────
# MCP server credentials are NOT managed in .env
# ──────────────────────────────────────────────────────────────────────
# Per-machine MCP server auth (context7 API key, github PAT) is configured
# at user scope, not via .env. See AGENTS.md for the canonical MCP policy.
# Anonymous tier works out-of-the-box for fresh clones.
