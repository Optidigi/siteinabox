---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/siab/Header.astro';
import Footer from '../components/siab/Footer.astro';
import FaqSection from '../components/siab/FaqSection.astro';

const pageTitle = 'Website intake';
const pageDescription = 'Vul de Site in a Box intake in voor je nieuwe website.';
const intakeApiUrl = import.meta.env.PUBLIC_INTAKE_API_URL ?? '/api/intake';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <section class="mt-180 lg-mt-80" aria-labelledby="intake-heading">
      <div class="container lg">
        <div class="row align-items-end">
          <div class="col-xl-8 col-lg-9">
            <div class="title-eleven mb-25">
              <h1 id="intake-heading">Vertel ons wat we moeten bouwen.</h1>
            </div>
            <p class="fs-22 text-dark opacity-75 m0">Na deze intake maken we een eerste websiteversie met je bedrijfsgegevens, pagina's, toon en inhoud als gestructureerde data.</p>
          </div>
          <div class="col-xl-4 col-lg-3 mt-25 text-lg-end">
            <a href="/contact" class="siab-secondary-link">Liever eerst contact?</a>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-50 lg-mt-30 mb-120" aria-label="Website intakeformulier">
      <div class="container lg">
        <form class="siab-intake" data-intake-form data-api-url={intakeApiUrl} novalidate>
          <div class="siab-intake__status" role="status" aria-live="polite" data-intake-status>
            Vul de verplichte velden in om je intake te versturen.
          </div>

          <div class="siab-intake__grid">
            <fieldset class="siab-intake__panel">
              <legend>Bedrijf</legend>

              <div class="siab-field" data-field="businessName">
                <label for="businessName">Bedrijfsnaam <span aria-hidden="true">*</span></label>
                <input id="businessName" name="businessName" type="text" autocomplete="organization" required />
                <p class="siab-error" data-error="businessName"></p>
              </div>

              <div class="siab-field" data-field="kvkNumber">
                <label for="kvkNumber">KvK-nummer <span class="siab-optional">(optioneel)</span></label>
                <input id="kvkNumber" name="kvkNumber" type="text" inputmode="numeric" autocomplete="off" />
                <p class="siab-field-help">Als de koppeling nog niet beschikbaar is, gebruiken we dit als handmatige bedrijfsreferentie.</p>
              </div>

              <div class="siab-field" data-field="domain">
                <label for="domain">Gewenst domein <span class="siab-optional">(optioneel)</span></label>
                <input id="domain" name="domain" type="text" inputmode="url" placeholder="jouwbedrijf.nl" />
                <p class="siab-field-help">Laat leeg als je nog geen domeinnaam hebt gekozen.</p>
              </div>

              <div class="siab-field" data-field="industry">
                <label for="industry">Branche <span class="siab-optional">(optioneel)</span></label>
                <input id="industry" name="industry" type="text" autocomplete="off" placeholder="Bijvoorbeeld kapper, coach of hovenier" />
              </div>

              <div class="siab-field" data-field="serviceArea">
                <label for="serviceArea">Werkgebied <span class="siab-optional">(optioneel)</span></label>
                <input id="serviceArea" name="serviceArea" type="text" placeholder="Amsterdam, Haarlem, Nederland" />
                <p class="siab-field-help">Scheid meerdere plaatsen met komma's.</p>
              </div>
            </fieldset>

            <fieldset class="siab-intake__panel">
              <legend>Contact</legend>

              <div class="siab-field" data-field="contactName">
                <label for="contactName">Naam contactpersoon <span aria-hidden="true">*</span></label>
                <input id="contactName" name="contactName" type="text" autocomplete="name" required />
                <p class="siab-error" data-error="contactName"></p>
              </div>

              <div class="siab-field" data-field="contactEmail">
                <label for="contactEmail">E-mailadres <span aria-hidden="true">*</span></label>
                <input id="contactEmail" name="contactEmail" type="email" autocomplete="email" required />
                <p class="siab-error" data-error="contactEmail"></p>
              </div>

              <div class="siab-field" data-field="contactPhone">
                <label for="contactPhone">Telefoon <span class="siab-optional">(optioneel)</span></label>
                <input id="contactPhone" name="contactPhone" type="tel" autocomplete="tel" inputmode="tel" />
              </div>

              <div class="siab-field" data-field="language">
                <label for="language">Taal</label>
                <select id="language" name="language">
                  <option value="nl" selected>Nederlands</option>
                  <option value="nl-en">Nederlands en Engels</option>
                </select>
              </div>
            </fieldset>
          </div>

          <fieldset class="siab-intake__panel mt-30">
            <legend>Website</legend>

            <div class="siab-check-grid" aria-label="Doelen">
              <label><input type="checkbox" name="goals" value="Professioneel online staan" checked /> Professioneel online staan</label>
              <label><input type="checkbox" name="goals" value="Nieuwe klanten laten aanvragen" /> Nieuwe klanten laten aanvragen</label>
              <label><input type="checkbox" name="goals" value="Beter vindbaar worden" checked /> Beter vindbaar worden</label>
              <label><input type="checkbox" name="goals" value="Diensten duidelijk uitleggen" /> Diensten duidelijk uitleggen</label>
            </div>

            <div class="siab-page-list mt-30" aria-label="Pagina's">
              <label><input type="checkbox" name="pages" value="home" data-title="Home" data-purpose="Homepage" checked /> Home</label>
              <label><input type="checkbox" name="pages" value="diensten" data-title="Diensten" data-purpose="Diensten en aanbod" checked /> Diensten</label>
              <label><input type="checkbox" name="pages" value="over-ons" data-title="Over ons" data-purpose="Vertrouwen en achtergrond" /> Over ons</label>
              <label><input type="checkbox" name="pages" value="contact" data-title="Contact" data-purpose="Contact en aanvraag" checked /> Contact</label>
            </div>

            <div class="siab-intake__grid mt-30">
              <div class="siab-field" data-field="tone">
                <label for="tone">Gewenste toon <span class="siab-optional">(optioneel)</span></label>
                <input id="tone" name="tone" type="text" placeholder="persoonlijk, zakelijk, rustig" />
                <p class="siab-field-help">Scheid meerdere woorden met komma's.</p>
              </div>

              <div class="siab-field" data-field="colors">
                <label for="colors">Kleuren <span class="siab-optional">(optioneel)</span></label>
                <input id="colors" name="colors" type="text" placeholder="#ffd80b, zwart, groen" />
              </div>
            </div>

            <div class="siab-field mt-25" data-field="notes">
              <label for="notes">Aanvullende informatie <span class="siab-optional">(optioneel)</span></label>
              <textarea id="notes" name="notes" rows="6" placeholder="Beschrijf je aanbod, doelgroep, sfeer, concurrenten of specifieke wensen."></textarea>
            </div>
          </fieldset>

          <div class="siab-intake__panel mt-30">
            <label class="siab-consent">
              <input id="privacyConsent" name="privacyConsent" type="checkbox" required />
              <span>Ik ga akkoord dat Site in a Box mijn gegevens gebruikt om mijn website-intake te verwerken. <a href="/privacy-policy">Zie ons privacybeleid</a>.</span>
            </label>
            <p class="siab-error" data-error="privacyConsent"></p>

            <input class="siab-honeypot" type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" />

            <div class="siab-submit-row">
              <button class="btn-eighteen siab-submit" type="submit" data-submit-button>Verstuur intake</button>
              <p class="siab-sla m0">Je intake wordt gevalideerd voordat de CMS-generatie start.</p>
            </div>
          </div>
        </form>
      </div>
    </section>

    <FaqSection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .siab-intake {
    display: block;
  }

  .siab-intake__status {
    background: #e8fff7;
    border: 2px solid var(--siab-border);
    box-shadow: 4px 4px var(--siab-shadow-color);
    color: var(--siab-text);
    font-family: 'Chivo', sans-serif;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 28px;
    padding: 18px 20px;
  }

  .siab-intake__status[data-state='error'] {
    background: #fff0f3;
  }

  .siab-intake__status[data-state='success'] {
    background: #e8fff7;
  }

  .siab-intake__status[data-state='pending'] {
    background: #fff9d8;
  }

  .siab-intake__grid {
    display: grid;
    gap: 30px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .siab-intake__panel {
    background: var(--siab-bg-surface);
    border: 2px solid var(--siab-border);
    box-shadow: 5px 5px var(--siab-shadow-color);
    padding: clamp(24px, 4vw, 42px);
  }

  .siab-intake__panel legend {
    color: var(--siab-text);
    float: none;
    font-family: 'Familjen Grotesk', sans-serif;
    font-size: 34px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 22px;
    width: auto;
  }

  .siab-field {
    display: block;
    margin-bottom: 22px;
  }

  .siab-field:last-child {
    margin-bottom: 0;
  }

  .siab-field > label,
  .siab-consent {
    color: var(--siab-text);
    display: block;
    font-family: 'Familjen Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .siab-optional,
  .siab-field-help,
  .siab-sla {
    color: var(--siab-text-muted);
    font-family: 'Chivo', sans-serif;
    font-size: 14px;
    font-weight: 400;
  }

  .siab-field-help {
    line-height: 1.45;
    margin: 8px 0 0;
  }

  .siab-field input,
  .siab-field select,
  .siab-field textarea {
    background: var(--siab-bg-surface);
    border: 2px solid var(--siab-border);
    border-radius: 0;
    color: var(--siab-text);
    font-family: 'Chivo', sans-serif;
    font-size: 17px;
    line-height: 1.4;
    min-height: 56px;
    padding: 14px 18px;
    width: 100%;
  }

  .siab-field textarea {
    min-height: 150px;
    resize: vertical;
  }

  .siab-field input:focus,
  .siab-field select:focus,
  .siab-field textarea:focus,
  .siab-consent input:focus-visible,
  .siab-check-grid input:focus-visible,
  .siab-page-list input:focus-visible {
    box-shadow: 3px 3px var(--siab-shadow-color);
    outline: 3px solid var(--siab-focus-ring);
    outline-offset: 2px;
  }

  .siab-check-grid,
  .siab-page-list {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .siab-check-grid label,
  .siab-page-list label,
  .siab-consent {
    align-items: flex-start;
    background: #fff;
    border: 2px solid var(--siab-border);
    display: flex;
    gap: 12px;
    line-height: 1.35;
    margin: 0;
    padding: 14px 16px;
  }

  .siab-check-grid input,
  .siab-page-list input,
  .siab-consent input {
    flex: 0 0 auto;
    margin-top: 4px;
  }

  .siab-error {
    color: #b00020;
    font-family: 'Chivo', sans-serif;
    font-size: 14px;
    line-height: 1.4;
    margin: 8px 0 0;
    min-height: 0;
  }

  .siab-honeypot {
    height: 1px;
    left: -9999px;
    opacity: 0;
    position: absolute;
    width: 1px;
  }

  .siab-submit-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 26px;
  }

  .siab-submit[disabled] {
    cursor: wait;
    opacity: .65;
  }

  .siab-secondary-link {
    color: var(--siab-text);
    font-family: 'Chivo', sans-serif;
    font-weight: 700;
    text-decoration: underline 2px solid var(--siab-border);
    text-underline-offset: 5px;
  }

  @media (max-width: 991px) {
    .siab-intake__grid,
    .siab-check-grid,
    .siab-page-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { IntakeSubmissionSchema } from '@siteinabox/contracts/generation';

  const form = document.querySelector('[data-intake-form]') as HTMLFormElement | null;
  const statusEl = document.querySelector('[data-intake-status]') as HTMLElement | null;
  const submitButton = document.querySelector('[data-submit-button]') as HTMLButtonElement | null;

  const splitList = (value: FormDataEntryValue | null): string[] =>
    String(value ?? '')
      .split(',')
      .map((entry) => entry.trim())
      .filter(Boolean);

  const textOrNull = (value: FormDataEntryValue | null): string | null => {
    const text = String(value ?? '').trim();
    return text || null;
  };

  const setStatus = (message: string, state: 'idle' | 'pending' | 'success' | 'error' = 'idle') => {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.dataset.state = state;
  };

  const clearErrors = () => {
    form?.querySelectorAll<HTMLElement>('[data-error]').forEach((entry) => {
      entry.textContent = '';
    });
  };

  const setFieldError = (field: string, message: string) => {
    const target = form?.querySelector<HTMLElement>(`[data-error="${field}"]`);
    if (target) target.textContent = message;
  };

  const pagePayload = (formEl: HTMLFormElement) =>
    Array.from(formEl.querySelectorAll<HTMLInputElement>('input[name="pages"]:checked')).map((entry) => ({
      slug: entry.value === 'home' ? 'home' : entry.value,
      title: entry.dataset.title ?? entry.value,
      purpose: entry.dataset.purpose ?? null,
    }));

  const buildPayload = (formEl: HTMLFormElement) => {
    const data = new FormData(formEl);
    const goals = data.getAll('goals').map(String).filter(Boolean);
    const pages = pagePayload(formEl);
    const kvkNumber = textOrNull(data.get('kvkNumber'));

    return {
      submittedAt: new Date().toISOString(),
      source: 'public-intake',
      businessName: textOrNull(data.get('businessName')) ?? '',
      domain: textOrNull(data.get('domain')),
      contactName: textOrNull(data.get('contactName')),
      contactEmail: textOrNull(data.get('contactEmail')),
      contactPhone: textOrNull(data.get('contactPhone')),
      language: textOrNull(data.get('language')) ?? 'nl',
      industry: textOrNull(data.get('industry')),
      serviceArea: splitList(data.get('serviceArea')),
      goals,
      pages: pages.length > 0 ? pages : [{ slug: 'home', title: 'Home', purpose: 'Homepage' }],
      brand: {
        colors: splitList(data.get('colors')),
        tone: splitList(data.get('tone')),
      },
      content: {
        kvk: {
          number: kvkNumber,
          enrichmentStatus: 'manual_not_enriched',
        },
        consent: {
          privacy: data.get('privacyConsent') === 'on',
          submittedFrom: window.location.href,
        },
      },
      notes: textOrNull(data.get('notes')),
    };
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearErrors();

    const data = new FormData(form);
    if (data.get('botcheck') === 'on') {
      form.reset();
      setStatus('Bedankt. Je intake is ontvangen.', 'success');
      return;
    }

    if (data.get('privacyConsent') !== 'on') {
      setFieldError('privacyConsent', 'Vink dit aan om je intake te kunnen versturen.');
      setStatus('Controleer de gemarkeerde velden.', 'error');
      return;
    }

    let hasClientError = false;
    if (!textOrNull(data.get('contactName'))) {
      setFieldError('contactName', 'Vul je naam in.');
      hasClientError = true;
    }
    const contactEmail = textOrNull(data.get('contactEmail'));
    const contactEmailInput = form.querySelector<HTMLInputElement>('#contactEmail');
    if (!contactEmail) {
      setFieldError('contactEmail', 'Vul je e-mailadres in.');
      hasClientError = true;
    } else if (contactEmailInput && !contactEmailInput.validity.valid) {
      setFieldError('contactEmail', 'Vul een geldig e-mailadres in.');
      hasClientError = true;
    }
    if (hasClientError) {
      setStatus('Controleer de gemarkeerde velden.', 'error');
      return;
    }

    const payload = buildPayload(form);
    const parsed = IntakeSubmissionSchema.safeParse(payload);
    if (!parsed.success) {
      for (const issue of parsed.error.issues) {
        const field = typeof issue.path[0] === 'string' ? issue.path[0] : 'businessName';
        setFieldError(field, issue.message);
      }
      setStatus('Controleer de gemarkeerde velden.', 'error');
      return;
    }

    const endpoint = form.dataset.apiUrl || '/api/intake';
    submitButton?.setAttribute('disabled', 'true');
    setStatus('Intake wordt gevalideerd en naar de CMS wachtrij gestuurd.', 'pending');

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(parsed.data),
      });
      const result = await response.json().catch(() => ({}));

      if (!response.ok || result?.ok === false) {
        const message = typeof result?.message === 'string'
          ? result.message
          : typeof result?.error?.message === 'string'
            ? result.error.message
            : 'De intake kon niet worden verwerkt. Probeer het later opnieuw.';
        setStatus(message, 'error');
        return;
      }

      const status = typeof result?.status === 'string' ? result.status : 'queued';
      if (status === 'preview_ready' || status === 'draft_ready') {
        setStatus('Je intake is ontvangen. De eerste websiteversie wordt klaargezet.', 'success');
      } else {
        setStatus(`Je intake is ontvangen met status: ${status}.`, 'success');
      }
      form.reset();
    } catch {
      setStatus('De intake-API is nu niet bereikbaar. Je gegevens zijn niet verstuurd.', 'error');
    } finally {
      submitButton?.removeAttribute('disabled');
    }
  });
</script>
