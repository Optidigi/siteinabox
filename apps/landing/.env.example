# Set to your site's canonical URL (https://yourdomain.com). Used for canonical/OG.
SITE_URL=https://example.com

# Optional: enable the Web3Forms-backed contact form. Get a free key at https://web3forms.com.
# When unset, ContactForm.astro renders a mailto: link instead.
PUBLIC_WEB3FORMS_KEY=

# Optional: contact email used by mailto fallback. Defaults to site.nap.email if set.
PUBLIC_CONTACT_EMAIL=

# Live preview (Wave 3) ------------------------------------------------
# Origin of the admin CMS that's allowed to embed the /__preview route
# in an iframe and post drafts via postMessage. Used both as the CSP
# frame-ancestors target and as the postMessage origin allowlist in
# PreviewIsland.tsx. Production: https://admin.siteinabox.nl
PUBLIC_ADMIN_ORIGIN=https://admin.siteinabox.nl

# HMAC secret used by the admin to sign preview tokens; the tenant's
# /__preview route verifies signed claims before rendering. MUST match
# the value set on the CMS (siab-payload's .env). Generate with
# `openssl rand -hex 32`. Both sides .trim() on read to defend against
# trailing whitespace from `echo "..." > .env`.
PREVIEW_HMAC_SECRET=
