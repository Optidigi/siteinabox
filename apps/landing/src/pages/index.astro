---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/siab/Header.astro';
import Footer from '../components/siab/Footer.astro';
import InfoTip from '../components/siab/InfoTip.astro';
import FaqSection from '../components/siab/FaqSection.astro';

const STARTUP_FEE_TIP = 'Eenmalig voor de bouw, domeinregistratie en inrichting. Daarna alleen je maandbedrag.';
const TIP_PROFESSIONAL = 'Een complete one-pager met je bedrijfsinfo, diensten, contact en een offerte- of afspraakknop.';
const TIP_FINDABLE = 'Je website wordt gevonden door zoekmachines én door AI-tools die mensen voor advies gebruiken.';
const TIP_EMAIL_FW = 'Mail naar info@jouwbedrijf.nl komt automatisch in je eigen Gmail of Outlook binnen.';
const TIP_MULTILANG = 'Je site komt in Nederlands en Engels, AI-vertaald met behoud van context en stijl.';
const TIP_GMAIL = 'Een volwaardige zakelijke mailbox: ontvangen én versturen vanaf je eigen domein.';
const TIP_GEMINI = 'Gemini helpt je e-mails schrijven, samenvatten en beantwoorden, direct in Gmail.';

const home = await getEntry('pages', 'index');
if (!home) {
  throw new Error('Missing required content entry: pages/index');
}

const ctaSignup = '/intake';
---

<BaseLayout
  title={home.data.title}
  description={home.data.description}
  ogImage={home.data.ogImage}
>
  <Header />

  <main>
  <!-- ============================== Above-the-fold (hero + cards strip) ============================== -->
  <div class="siab-above-fold">
  <!-- ============================== Hero ============================== -->
  <section class="hero-banner-nine z-1 position-relative pt-225 md-pt-150 pb-225 xl-pb-200 md-pb-120" aria-label="Introductie">
    <div class="container lg">
      <div class="row">
        <div class="col-lg-6 d-flex flex-column justify-content-center">
          {/* Space before <br /> is intentional: the <br /> is hidden on mobile via siab-overrides.css so the heading wraps as one string; the space preserves natural word spacing in that mode. */}
          <h1 class="hero-heading">Een website voor je bedrijf. <br />Zonder gedoe.</h1>
          <p class="fs-24 text-dark pt-35 lg-pt-30 pe-xxl-5">Online binnen 3 werkdagen · Geen verrassingen ·<span class="d-block d-sm-inline"> Alleen betalen als je tevreden bent.</span></p>
          <p class="fs-22 pt-30 lg-pt-20 mb-0">Vanaf <span class="fw-500 text-dark">€19</span>/maand</p>
          <div class="siab-cta-group d-flex align-items-center flex-wrap gap-3 pt-15">
            <a href={ctaSignup} class="btn-eighteen">Maak mijn website</a>
            <a href="#zo-werkt-het" class="siab-see-how">Hoe werkt het? →</a>
          </div>
        </div>
        <div class="col-12 col-lg-6 mt-4 mt-lg-0">
          <div class="illustration">
            <div
              id="hero-rocket"
              class="lottie-rocket"
              role="img"
              aria-label="Animatie: jouw bedrijfswebsite klaar voor lancering"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== Promise cards (purple strip, seamless with reassurance below) ============================== -->
  <section class="hero-cards-strip" aria-labelledby="onze-belofte-heading">
    <h2 id="onze-belofte-heading" class="visually-hidden">Onze belofte</h2>
    <div class="container lg">
      <div class="row gx-xxl-5">
        <div class="col-lg-4">
          <div class="card-style-eleven">
            <div class="card-icon-circle card-icon-cyan"><img src="/theme/images/icon/tabler-tools.svg" alt="" /></div>
            <h3 class="card-style-eleven-heading">Wij regelen het</h3>
            <p class="m0">Een korte vragenlijst, een paar foto's en wat tekst. Wij doen de rest.</p>
            <div class="d-flex justify-content-end">
              <a href="#zo-werkt-het" class="stretched-link" aria-label="Bekijk hoe het werkt"><img src="/theme/images/icon/icon_49.svg" alt="" /></a>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card-style-eleven md-mt-30">
            <div class="card-icon-circle card-icon-orange"><img src="/theme/images/icon/tabler-adjustments-horizontal.svg" alt="" /></div>
            <h3 class="card-style-eleven-heading">Jij hebt de regie</h3>
            <p class="m0">Van je foto's tot je openingstijden: allemaal gemakkelijk zelf aan te passen.</p>
            <div class="d-flex justify-content-end">
              <a href="#zo-werkt-het" class="stretched-link" aria-label="Bekijk hoe het werkt"><img src="/theme/images/icon/icon_49.svg" alt="" /></a>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card-style-eleven md-mt-30">
            <div class="card-icon-circle card-icon-green"><img src="/theme/images/icon/tabler-shield-check.svg" alt="" /></div>
            <h3 class="card-style-eleven-heading">Geen onderhoud</h3>
            <p class="m0">Updates, beveiliging en back-ups verzorgen wij. Geen zorgen voor jou.</p>
            <div class="d-flex justify-content-end">
              <a href="#zo-werkt-het" class="stretched-link" aria-label="Bekijk hoe het werkt"><img src="/theme/images/icon/icon_49.svg" alt="" /></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  </div>

  <!-- ============================== Audience reassurance (continues purple seamlessly) ============================== -->
  <section class="block-feature-twentyFour pb-80 lg-pb-40" aria-labelledby="audience-heading">
    <div class="container lg">
      <h3 id="audience-heading" class="siab-heading">Voor elke starter die professioneel online wil staan.</h3>

      <!-- Infinite marquee: beroepsnamen scrollen rechts naar links. CSS-only. -->
      <div class="siab-marquee" aria-label="Voor deze beroepen werken wij">
        <div class="siab-marquee__viewport">
          <ul class="siab-marquee__track">
            <li>kapper</li>
            <li>schilder</li>
            <li>coach</li>
            <li>fotograaf</li>
            <li>hovenier</li>
            <li>personal trainer</li>
            <li>loodgieter</li>
            <li>klusser</li>
            <li>schoonheidsspecialist</li>
            <li>timmerman</li>
            <li>stukadoor</li>
            <li>kok</li>
          </ul>
          <ul class="siab-marquee__track" aria-hidden="true">
            <li>kapper</li>
            <li>schilder</li>
            <li>coach</li>
            <li>fotograaf</li>
            <li>hovenier</li>
            <li>personal trainer</li>
            <li>loodgieter</li>
            <li>klusser</li>
            <li>schoonheidsspecialist</li>
            <li>timmerman</li>
            <li>stukadoor</li>
            <li>kok</li>
          </ul>
        </div>
      </div>

      <ul class="siab-perks">
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          Vindbaar in Google én ChatGPT
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          Zelf aanpassen, zonder technische kennis
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          Niet tevreden? Geen factuur.
        </li>
      </ul>
    </div>
  </section>

  <!-- ============================== Zo werkt het ============================== -->
  <section id="zo-werkt-het" class="block-feature-twentySix mt-180 xl-mt-150 lg-mt-80" aria-labelledby="zo-werkt-het-heading">
    <div class="container lg">
      <div class="row">
        <div class="col-xl-7 col-lg-7 m-auto">
          <div class="title-eleven text-center mb-30 lg-mb-10">
            <h2 id="zo-werkt-het-heading">Zo werkt het.</h2>
          </div>
        </div>
      </div>
      <div class="row gx-xxl-5">
        <div class="col-lg-4 d-flex">
          <div class="block-one d-flex flex-column justify-content-center w-100 mt-50 lg-mt-30">
            <div>
              <img src="/theme/images/icon/icon_53.svg" alt="" />
              <h3>Een vragenlijst van een kwartier, meer niet.</h3>
            </div>
          </div>
        </div>
        <div class="col-lg-8 d-flex">
          <div class="block-two w-100 mt-50 lg-mt-30">
            <div class="row">
              <div class="col-xl-8 col-lg-7">
                <h3 class="md-mt-20">Zo ziet een website van Site in a Box eruit.</h3>
              </div>
            </div>
            <div class="device-stack">
              <!-- Safari frame (Magic UI, simple variant) -->
              <div class="safari-frame">
                <div class="safari-screen">
                  <img src="/theme/images/assets/example-desktop.webp" alt="Voorbeeld bedrijfswebsite op desktop" width="1200" height="750" loading="lazy" decoding="async" />
                </div>
                <svg viewBox="0 0 1203 753" fill="none" xmlns="http://www.w3.org/2000/svg" class="safari-chrome" aria-hidden="true">
                  <defs>
                    <mask id="safariPunch" maskUnits="userSpaceOnUse">
                      <rect x="0" y="0" width="1203" height="753" fill="white"/>
                      <path d="M1 52H1201V741C1201 747.075 1196.08 752 1190 752H12C5.92486 752 1 747.075 1 741V52Z" fill="black"/>
                    </mask>
                    <clipPath id="safariClip">
                      <rect width="1203" height="753" fill="white"/>
                    </clipPath>
                  </defs>
                  <g clip-path="url(#safariClip)" mask="url(#safariPunch)">
                    <path d="M0 52H1202V741C1202 747.627 1196.63 753 1190 753H12C5.37258 753 0 747.627 0 741V52Z" fill="#E5E5E5"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M0 12C0 5.37258 5.37258 0 12 0H1190C1196.63 0 1202 5.37258 1202 12V52H0L0 12Z" fill="#E5E5E5"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M1.06738 12C1.06738 5.92487 5.99225 1 12.0674 1H1189.93C1196.01 1 1200.93 5.92487 1200.93 12V51H1.06738V12Z" fill="white"/>
                    <circle cx="27" cy="25" r="6" fill="#E5E5E5"/>
                    <circle cx="47" cy="25" r="6" fill="#E5E5E5"/>
                    <circle cx="67" cy="25" r="6" fill="#E5E5E5"/>
                  </g>
                </svg>
              </div>
              <!-- iPhone 15 Pro frame (Magic UI) -->
              <div class="iphone-frame">
                <div class="iphone-screen">
                  <img src="/theme/images/assets/example-mobile.webp" alt="Voorbeeld bedrijfswebsite op mobiel" width="430" height="880" loading="lazy" decoding="async" />
                </div>
                <svg viewBox="0 0 433 882" fill="none" xmlns="http://www.w3.org/2000/svg" class="iphone-chrome" aria-hidden="true">
                  <defs>
                    <mask id="iphonePunch" maskUnits="userSpaceOnUse">
                      <rect x="0" y="0" width="433" height="882" fill="white"/>
                      <rect x="21.25" y="19.25" width="389.5" height="843.5" rx="55.75" ry="55.75" fill="black"/>
                    </mask>
                  </defs>
                  <g mask="url(#iphonePunch)">
                    <path d="M2 73C2 32.6832 34.6832 0 75 0H357C397.317 0 430 32.6832 430 73V809C430 849.317 397.317 882 357 882H75C34.6832 882 2 849.317 2 809V73Z" fill="#1d1d1f"/>
                    <path d="M0 171C0 170.448 0.447715 170 1 170H3V204H1C0.447715 204 0 203.552 0 203V171Z" fill="#1d1d1f"/>
                    <path d="M1 234C1 233.448 1.44772 233 2 233H3.5V300H2C1.44772 300 1 299.552 1 299V234Z" fill="#1d1d1f"/>
                    <path d="M1 319C1 318.448 1.44772 318 2 318H3.5V385H2C1.44772 385 1 384.552 1 384V319Z" fill="#1d1d1f"/>
                    <path d="M430 279H432C432.552 279 433 279.448 433 280V384C433 384.552 432.552 385 432 385H430V279Z" fill="#1d1d1f"/>
                    <path d="M6 74C6 35.3401 37.3401 4 76 4H356C394.66 4 426 35.3401 426 74V808C426 846.66 394.66 878 356 878H76C37.3401 878 6 846.66 6 808V74Z" fill="white"/>
                  </g>
                </svg>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-8 d-flex">
          <div class="block-three w-100 mt-50 lg-mt-30">
            <div class="row">
              <div class="col-md-8 ms-auto text-end">
                <div class="icon d-flex align-items-center justify-content-center rounded-circle"><img src="/theme/images/icon/icon_54.svg" alt="" /></div>
                <blockquote>"Strak, modern en mooi design. Mensen merken het op.<br />Een echte aanrader."</blockquote>
                <div class="name fs-20"><span class="fw-500 text-dark">Ardi.</span> Amblast</div>
              </div>
            </div>
            <img src="/theme/images/assets/avatar_4.webp" alt="" class="shapes shape_01" loading="lazy" decoding="async" />
            <img src="/theme/images/shape/shape_80.svg" alt="" class="shapes shape_02" />
          </div>
        </div>
        <div class="col-lg-4 d-flex">
          <div class="block-four d-flex flex-column justify-content-center w-100 mt-50 lg-mt-30">
            <div>
              <h3>Eerste versie binnen 24 uur, online binnen 3 werkdagen.</h3>
              <img src="/theme/images/icon/icon_55.svg" alt="" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== Vertrouwens-trio ============================== -->
  <section class="block-feature-twentyFive mt-180 lg-mt-80" aria-labelledby="garanties-heading">
    <h2 id="garanties-heading" class="visually-hidden">Onze garanties</h2>
    <div class="container lg">
      <div class="border-top border-bottom border-dark border-2 pt-90 lg-pt-40 pb-90 lg-pb-40">
        <div class="row gx-xxl-5">
          <div class="col-lg-4">
            <div class="card-style-twelve text-center mt-20">
              <div class="card-icon-circle-twelve card-icon-yellow"><img src="/theme/images/icon/tabler-clipboard-list.svg" alt="" /></div>
              <h3 class="card-style-twelve-heading">Jij levert input, wij bouwen</h3>
              <p class="pe-xxl-4 ps-xxl-4">Een 15 minuten vragenlijst en wat foto's. Wij verwerken het tot je website.</p>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="card-style-twelve text-center mt-20">
              <div class="card-icon-circle-twelve card-icon-green"><img src="/theme/images/icon/tabler-shield-lock.svg" alt="" /></div>
              <h3 class="card-style-twelve-heading">AVG en cookies geregeld</h3>
              <p class="pe-xxl-4 ps-xxl-4">Privacyverklaring en cookiemelding zitten standaard ingebouwd.</p>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="card-style-twelve text-center mt-20">
              <div class="card-icon-circle-twelve card-icon-orange"><img src="/theme/images/icon/tabler-edit.svg" alt="" /></div>
              <h3 class="card-style-twelve-heading">Aanpassen kan altijd</h3>
              <p class="pe-xxl-4 ps-xxl-4">Tekst, foto's of openingstijden? Pas zelf aan via je beheeromgeving.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== Prijzen ============================== -->
  <section id="prijzen" class="pricing-section-six mt-170 lg-mt-80" aria-labelledby="prijzen-heading">
    <div class="container lg">
      <div class="row">
        <div class="col-xl-4 col-lg-6 m-auto m-xl-0 text-center text-xl-start">
          <div class="title-eleven">
            <h2 id="prijzen-heading">Eén prijs. Alles inbegrepen.</h2>
            <p class="fs-20 text-dark opacity-75 pt-25 pe-xxl-5">Eén ding minder om te regelen voor je nieuwe bedrijf. Wij doen de techniek, jij houdt je bezig met je klanten.</p>
          </div>
          <div class="fs-20 fw-500 text-dark mt-55 lg-mt-40 mb-15">Facturatie</div>
          <nav class="pricing-nav-four d-flex justify-content-center justify-content-xl-start">
            <div class="nav nav-tabs justify-content-between" role="tablist">
              <a class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab" aria-controls="monthly" aria-selected="false">Maandelijks</a>
              <a class="nav-link active" id="yearly-tab" data-bs-toggle="tab" data-bs-target="#yearly" type="button" role="tab" aria-controls="yearly" aria-selected="true">Jaarlijks</a>
            </div>
          </nav>
          <p class="fs-14 opacity-75 mt-2 mb-0 text-center text-xl-start lg-mb-40">Alle prijzen excl. btw</p>
        </div>
        <div class="col-xl-8">
          <div class="tab-content ps-xxl-5">
            <!-- Monthly -->
            <div class="tab-pane fade" id="monthly" role="tabpanel" aria-labelledby="monthly-tab" tabindex="0">
              <div class="row">
                <div class="col-lg-6 d-flex">
                  <div class="pr-column w-100">
                    <div class="pr-header text-center mb-25">
                      <div class="plane-name">Website</div>
                      <div class="plan-tagline">Jouw bedrijfswebsite, helemaal verzorgd</div>
                      <div class="save-line fs-20 fw-500">Maandelijks opzegbaar</div>
                      <div class="price">€19<sub>/maand*</sub></div>
                      <div class="info2 fs-14 opacity-75">* €99 eenmalige opstartkosten <InfoTip title={STARTUP_FEE_TIP} label="Meer info over opstartkosten" /></div>
                    </div>
                    <a href={ctaSignup} class="btn-eleven w-100 d-flex justify-content-between align-items-center">Start vrijblijvend<span class="icon tran3s d-flex align-items-center justify-content-center"><svg class="cta-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6l-6 6"/></svg></span></a>
                    <h3 class="pricing-section-heading">Inbegrepen</h3>
                    <ul class="style-none package-feature">
                      <li>Professionele website <InfoTip title={TIP_PROFESSIONAL} /></li>
                      <li>Vindbaar in Google én ChatGPT <InfoTip title={TIP_FINDABLE} /></li>
                      <li>Bliksemsnelle laadtijd</li>
                      <li>Veilig en altijd online</li>
                      <li>Eigen .nl-domein</li>
                      <li>E-mail forwarding <InfoTip title={TIP_EMAIL_FW} /></li>
                      <li>NL-support</li>
                    </ul>
                  </div>
                </div>
                <div class="col-lg-6 d-flex">
                  <div class="pr-column pr-column-recommended w-100 md-mt-30">
                    <div class="pr-header text-center mb-25">
                      <div class="plane-name">Compleet</div>
                      <div class="plan-tagline">Website én zakelijke Gmail</div>
                      <div class="save-line fs-20 fw-500">Maandelijks opzegbaar</div>
                      <div class="price">€29<sub>/maand*</sub></div>
                      <div class="info2 fs-14 opacity-75">* €99 eenmalige opstartkosten <InfoTip title={STARTUP_FEE_TIP} label="Meer info over opstartkosten" /></div>
                    </div>
                    <a href={ctaSignup} class="btn-eleven w-100 d-flex justify-content-between align-items-center">Start vrijblijvend<span class="icon tran3s d-flex align-items-center justify-content-center"><svg class="cta-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6l-6 6"/></svg></span></a>
                    <h3 class="pricing-section-heading plus-header">Alles van Website, plus:</h3>
                    <ul class="style-none package-feature">
                      <li>Meertalige website <InfoTip title={TIP_MULTILANG} /></li>
                      <li>Zakelijke Gmail (info@jouwbedrijf.nl) <InfoTip title={TIP_GMAIL} /></li>
                      <li>AI-assistent Gemini in Gmail <InfoTip title={TIP_GEMINI} /></li>
                      <li>Chat met AI in de Gemini-app</li>
                      <li>30 GB Google Drive</li>
                      <li>Google Agenda + Meet</li>
                      <li class="optional">Google Analytics-setup</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <!-- Yearly (default active) -->
            <div class="tab-pane show active fade" id="yearly" role="tabpanel" aria-labelledby="yearly-tab" tabindex="0">
              <div class="row">
                <div class="col-lg-6 d-flex">
                  <div class="pr-column w-100">
                    <div class="pr-header text-center mb-25">
                      <div class="plane-name">Website</div>
                      <div class="plan-tagline">Jouw bedrijfswebsite, helemaal verzorgd</div>
                      <div class="save-line fs-20 fw-500">Geen opstartkosten</div>
                      <div class="price">€19<sub>/maand</sub></div>
                    </div>
                    <a href={ctaSignup} class="btn-eleven w-100 d-flex justify-content-between align-items-center">Start vrijblijvend<span class="icon tran3s d-flex align-items-center justify-content-center"><svg class="cta-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6l-6 6"/></svg></span></a>
                    <h3 class="pricing-section-heading">Inbegrepen</h3>
                    <ul class="style-none package-feature">
                      <li>Professionele website <InfoTip title={TIP_PROFESSIONAL} /></li>
                      <li>Vindbaar in Google én ChatGPT <InfoTip title={TIP_FINDABLE} /></li>
                      <li>Bliksemsnelle laadtijd</li>
                      <li>Veilig en altijd online</li>
                      <li>Eigen .nl-domein</li>
                      <li>E-mail forwarding <InfoTip title={TIP_EMAIL_FW} /></li>
                      <li>NL-support</li>
                    </ul>
                  </div>
                </div>
                <div class="col-lg-6 d-flex">
                  <div class="pr-column pr-column-recommended w-100 md-mt-30">
                    <div class="pr-header text-center mb-25">
                      <div class="plane-name">Compleet</div>
                      <div class="plan-tagline">Website én zakelijke Gmail</div>
                      <div class="save-line fs-20 fw-500">Geen opstartkosten</div>
                      <div class="price">€29<sub>/maand</sub></div>
                    </div>
