---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/siab/Header.astro';
import Footer from '../components/siab/Footer.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import FaqSection from '../components/siab/FaqSection.astro';
import { site } from '../content/site';

const pageTitle = 'Contact';
const pageDescription = 'Stuur Site in a Box een bericht. We lezen elk bericht en komen zo snel mogelijk bij je terug.';

const directEmail = 'info@siteinabox.nl';
// PLACEHOLDER: vervang door echte WhatsApp Business-nummer voor de live-zetting.
const whatsappDisplay = '+31 6 12 34 56 78';
const whatsappHref = 'https://wa.me/31612345678';
// PLACEHOLDER: vervang door echte telefoonnummer, of verwijder dit blok als geen telefoon gepubliceerd wordt.
const phoneDisplay = '+31 6 12 34 56 78';
const phoneHref = 'tel:+31612345678';
// PLACEHOLDER: bevestig openingstijden voor de live-zetting.
const officeHours = 'Ma–Vr · 09:00–17:00';

const contactPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact — Site in a Box',
  url: 'https://siteinabox.nl/contact',
  inLanguage: 'nl',
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <section class="mt-180 lg-mt-80" aria-labelledby="contact-heading">
      <div class="container lg">
        <div class="row">
          <div class="col-xl-8 col-lg-10 m-auto text-center">
            <div class="title-eleven mb-30 lg-mb-10">
              <h1 id="contact-heading">Stuur ons een bericht.</h1>
            </div>
            <p class="fs-22 text-dark opacity-75 m0">Een vraag, een idee, of gewoon even sparren? We lezen elk berichtje.</p>

            <ul class="siab-trust-perks" aria-label="Onze beloftes">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Online binnen 3 werkdagen
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Geen verrassingen
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                Alleen betalen als je tevreden bent
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-50 lg-mt-30" aria-label="Contactformulier en directe contactgegevens">
      <div class="container lg">
        <div class="row gx-xxl-5 align-items-stretch">
          <div class="col-lg-7 d-flex mt-30 lg-mt-30">
            <ContactForm />
          </div>
          <div class="col-lg-5 d-flex mt-30 lg-mt-30">
            <aside class="siab-info-card" aria-label="Direct contact en bereikbaarheid">

              <div class="siab-info-group">
                <p class="siab-info-eyebrow">Direct contact</p>

                <a class="siab-info-row siab-info-row--email" href={`mailto:${directEmail}`} aria-label={`Stuur een e-mail naar ${directEmail}`}>
                  <span class="siab-info-row__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="m3 7 9 6 9-6"/></svg>
                  </span>
                  <span class="siab-info-row__value">{directEmail}</span>
                </a>

                {/* PLACEHOLDER: WhatsApp-nummer en wa.me-link bevestigen voor live-zetting */}
                <a class="siab-info-row siab-info-row--wa" href={whatsappHref} aria-label={`Chat via WhatsApp met ${whatsappDisplay}`}>
                  <span class="siab-info-row__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>
                  </span>
                  <span class="siab-info-row__value">{whatsappDisplay}</span>
                </a>

                {/* PLACEHOLDER: telefoonnummer bevestigen voor live-zetting */}
                <a class="siab-info-row siab-info-row--phone" href={phoneHref} aria-label={`Bel ons op ${phoneDisplay}`}>
                  <span class="siab-info-row__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </span>
                  <span class="siab-info-row__value">{phoneDisplay}</span>
                </a>
              </div>

              <hr class="siab-info-divider" />

              <div class="siab-info-group">
                <p class="siab-info-eyebrow">Bereikbaarheid</p>
                {/* PLACEHOLDER: openingstijden bevestigen */}
                <p class="siab-info-line">{officeHours}</p>
              </div>

              <hr class="siab-info-divider" />

              <div class="siab-info-group siab-info-group--socials">
                <p class="siab-info-eyebrow">Volg ons</p>
                {site.socials.instagram && (
                  <a
                    class="siab-info-social"
                    href={site.socials.instagram}
                    rel="noopener"
                    target="_blank"
                    aria-label="Site in a Box op Instagram (opent in nieuw tabblad)"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="4"/><circle cx="12" cy="12" r="3"/><line x1="16.5" y1="7.5" x2="16.501" y2="7.5"/></svg>
                    <span>Instagram</span>
                  </a>
                )}
              </div>

            </aside>
          </div>
        </div>
      </div>
    </section>

    <FaqSection />
  </main>
  <Footer />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(contactPageJsonLd)} />
</BaseLayout>

<style>
  .siab-info-card {
    background: var(--siab-bg-surface);
    border: 2px solid var(--siab-border);
    border-radius: 0;
    padding: clamp(28px, 4vw, 44px);
    box-shadow: 5px 5px var(--siab-shadow-color);
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .siab-info-group { display: flex; flex-direction: column; gap: 4px; }
  .siab-info-group--socials { margin-top: auto; }

  .siab-info-eyebrow {
    font-family: 'Chivo', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--siab-text-muted);
    margin: 0 0 10px;
  }

  .siab-info-row {
    display: flex;
    align-items: center;
    gap: 14px;
    min-height: 44px;
    padding: 6px 0;
    color: var(--siab-text);
    text-decoration: none;
    border-radius: 0;
    transition: color .12s;
  }
  .siab-info-row:hover .siab-info-row__value {
    text-decoration: underline 2px solid var(--siab-border);
    text-underline-offset: 4px;
  }
  .siab-info-row:focus-visible {
    outline: 3px solid var(--siab-focus-ring);
    outline-offset: 3px;
  }

  .siab-info-row__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--siab-text);
  }
  .siab-info-row--email .siab-info-row__icon { color: #06b4ff; }
  .siab-info-row--wa .siab-info-row__icon { color: #00c592; }
  .siab-info-row--phone .siab-info-row__icon { color: #f96a00; }

  .siab-info-row__value {
    font-family: 'Chivo', sans-serif;
    font-weight: 500;
    font-size: 17px;
    line-height: 1.3;
    color: var(--siab-text);
    word-break: break-word;
  }

  .siab-info-divider {
    border: 0;
    height: 1px;
    background: var(--siab-border);
    opacity: 0.15;
    margin: 22px 0;
  }

  .siab-info-line {
    font-family: 'Chivo', sans-serif;
    font-weight: 500;
    font-size: 17px;
    line-height: 1.5;
    color: var(--siab-text);
    margin: 0 0 6px;
  }
  .siab-info-line:last-child { margin-bottom: 0; }

  .siab-info-social {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
    padding: 6px 0;
    font-family: 'Chivo', sans-serif;
    font-weight: 600;
    font-size: 16px;
    color: var(--siab-text);
    text-decoration: none;
  }
  .siab-info-social:hover span {
    text-decoration: underline 2px solid var(--siab-border);
    text-underline-offset: 4px;
  }
  .siab-info-social:focus-visible {
    outline: 3px solid var(--siab-focus-ring);
    outline-offset: 3px;
  }

  @media (max-width: 991px) {
    .siab-info-card { box-shadow: 4px 4px var(--siab-shadow-color); }
    .siab-info-divider { margin: 18px 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .siab-info-row { transition: none; }
  }

  /* Intro trust strip — mirrors the homepage perks vocabulary, adapted to a white surface */
  .siab-trust-perks {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 32px;
  }
  .siab-trust-perks li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Chivo', sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
    color: var(--siab-text);
  }
  .siab-trust-perks svg {
    /* Check stroke stays black in both themes — the circle is yellow in light AND dark. */
    color: #000;
    flex-shrink: 0;
    background: #f5e900;
    border: 2px solid var(--siab-border);
    border-radius: 50%;
    width: 26px;
    height: 26px;
    padding: 3px;
  }
  @media (max-width: 575px) {
    .siab-trust-perks { gap: 10px 20px; margin-top: 22px; }
    .siab-trust-perks li { font-size: 14px; }
  }
</style>
