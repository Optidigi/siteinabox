---
import { site } from '../../content/site';

type PageType = 'WebPage' | 'ContactPage';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  pageType?: PageType;
  hasFaq?: boolean;
}

const {
  title,
  description,
  noindex = false,
  pageType = 'WebPage',
  hasFaq = false,
} = Astro.props;

const baseUrl = `https://${site.primaryDomain}`;
const pageUrl = new URL(Astro.url.pathname, baseUrl).toString();
const pageId = Astro.url.pathname === '/' ? `${baseUrl}/#home` : `${pageUrl}#webpage`;
const organizationId = `${baseUrl}/#organization`;
const websiteId = `${baseUrl}/#website`;
const serviceId = `${baseUrl}/#website-service`;
const offerCatalogId = `${baseUrl}/#website-packages`;
const llmsDocumentId = `${baseUrl}/llms.txt#document`;
const pricingUrl = `${baseUrl}/#prijzen`;
const logoUrl = new URL('/theme/images/logo/siab_logo.svg', baseUrl).toString();

const fullTitle = title === site.brand ? title : `${title} | ${site.brand}`;
const pageSchemaType = pageType;

const faqItems = [
  {
    q: 'Hoe weten jullie wat er op mijn website moet komen?',
    a: 'Via een korte vragenlijst van ongeveer 15 minuten. Je vertelt ons wat voor bedrijf je hebt, wie je klanten zijn, en welke stijl je aanspreekt. Je levert wat foto’s aan en eventueel je logo. Wij maken op basis daarvan de eerste versie van je website, inclusief teksten. In de feedbackronde stuur jij alles helemaal naar jouw smaak bij.',
  },
  {
    q: 'Wat kost Site in a Box, en wat zit erbij?',
    a: 'Bij jaarbetaling betaal je €190 per jaar vooraf (ongeveer €16 per maand). Zo bespaar je €38 per jaar (17%). Liever maandelijks? Dan is het €19 per maand, opzegbaar. Erbij: professionele website, klaar voor Google én ChatGPT, snelle laadtijd, veilig online, .nl-domein eerste jaar gratis (of je huidige domein), zelf teksten en foto’s aanpassen, NL-support. Optioneel: zakelijke e-mail.',
  },
  {
    q: 'Wat betekent “alleen betalen als je tevreden bent” precies?',
    a: 'Wij bouwen je website eerst. Je krijgt ’m te zien op een testadres (bijvoorbeeld jouwbedrijf.siteinabox.nl). Pas wanneer jij actief akkoord geeft, een klik op de bevestigingslink of een mailtje van jouw kant, sturen we de factuur en gaan we live. Geef je geen akkoord, dan betaal je niets.',
  },
  {
    q: 'Wat als de eerste versie niet helemaal goed is?',
    a: 'Geen probleem. Geef je belangrijkste feedback in één keer door. Wij verwerken de aanpassingen die binnen het pakket passen. Komen we er niet uit, dan stop je zonder factuur.',
  },
  {
    q: 'Past mijn bedrijf op één pagina?',
    a: 'Voor de meeste net-gestarte bedrijven: ja. Een one-pager werkt goed als je een dienst aanbiedt waar potentiële klanten vooral willen weten wie je bent, wat je doet, voor wie, en hoe ze je kunnen bereiken. Heb je iets uitgebreiders nodig zoals een webshop of online cursus? Dan kijken we graag wat mogelijk is en maken we zo nodig een apart voorstel.',
  },
  {
    q: 'Kan ik per maand opzeggen?',
    a: 'Bij maandelijkse facturatie kun je vanaf dag één per maand opzeggen, met één maand opzegtermijn. Bij jaarbetaling betaal je het eerste jaar in één keer vooruit (€190). Na dat jaar wordt het maandelijks en kun je elk moment opzeggen.',
  },
  {
    q: 'Wie is eigenaar van mijn domein en website?',
    a: 'Je domein en content zijn van jou. Stop je later met Site in a Box, dan kun je je domein en eigen content meenemen. De website zelf bouwen en hosten wij in ons eigen systeem.',
  },
  {
    q: 'Kan ik zelf dingen aanpassen na lancering?',
    a: 'Het meeste pas je zelf aan in de beheeromgeving: openingstijden, prijzen, foto’s, teksten en diensten. Geen technische kennis nodig, gewoon klikken en typen, zo vaak als je wilt. Hulp nodig of wil je iets groters aanpassen? Stuur ons een bericht, dan kijken we wat mogelijk is en wat het kost.',
  },
];

const includedFeatures = [
  'Professionele website',
  'Klaar voor Google en ChatGPT',
  'Bliksemsnelle laadtijd',
  'Veilig en betrouwbaar online',
  '.nl-domein eerste jaar gratis',
  'Zelf teksten en foto’s aanpassen',
  'NL-support',
];

const optionalFeatures = [
  'Zakelijke e-mail',
];

const monthlyPriceSpecification = (price: number) => ({
  '@type': 'UnitPriceSpecification',
  price,
  priceCurrency: 'EUR',
  unitText: 'MONTH',
  valueAddedTaxIncluded: false,
});

const yearlyPriceSpecification = (price: number) => ({
  '@type': 'UnitPriceSpecification',
  price,
  priceCurrency: 'EUR',
  unitText: 'YEAR',
  valueAddedTaxIncluded: false,
});

const graph = [
  {
    '@type': 'Organization',
    '@id': organizationId,
    name: 'Optidigi',
    legalName: 'Optidigi',
    alternateName: site.brand,
    url: `${baseUrl}/`,
    logo: logoUrl,
    description: site.description,
    email: 'info@siteinabox.nl',
    telephone: '+31625052591',
    areaServed: site.serviceArea ?? ['Nederland'],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Roermond',
      addressCountry: 'NL',
    },
    identifier: [
      {
        '@type': 'PropertyValue',
        propertyID: 'KvK',
        value: '99460165',
      },
      {
        '@type': 'PropertyValue',
        propertyID: 'BTW-id',
        value: 'NL869001073B01',
      },
    ],
    vatID: 'NL869001073B01',
    sameAs: Object.values(site.socials).filter(Boolean),
    contactPoint: [
      {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: 'info@siteinabox.nl',
        telephone: '+31625052591',
        areaServed: site.serviceArea ?? ['NL'],
        availableLanguage: ['Dutch'],
      },
    ],
    subjectOf: [
      { '@id': websiteId },
      { '@id': `${baseUrl}/#home` },
      { '@id': llmsDocumentId },
    ],
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: `${baseUrl}/`,
    name: site.brand,
    description: site.description,
    inLanguage: 'nl-NL',
    publisher: { '@id': organizationId },
    about: { '@id': serviceId },
  },
  {
    '@type': pageSchemaType,
    '@id': pageId,
    url: pageUrl,
    name: fullTitle,
    description,
    isPartOf: { '@id': websiteId },
    inLanguage: 'nl-NL',
    publisher: { '@id': organizationId },
    about: [
      { '@id': organizationId },
      { '@id': serviceId },
    ],
    ...(Astro.url.pathname === '/'
      ? { mainEntity: { '@id': serviceId } }
      : {}),
  },
  {
    '@type': 'Service',
    '@id': serviceId,
    name: 'Site in a Box website abonnement',
    alternateName: ['Site in a Box'],
    serviceType: 'Website laten maken, hosting en beheeromgeving',
    category: ['Website laten maken', 'Website abonnement', 'Webdesign', 'Hosting'],
    url: `${baseUrl}/`,
    description: site.description,
    provider: { '@id': organizationId },
    areaServed: {
      '@type': 'Country',
      name: 'Nederland',
    },
    audience: {
      '@type': 'BusinessAudience',
      name: 'Net-gestarte ondernemers, ZZP-dienstverleners, lokale bedrijven en freelancers in Nederland',
    },
    mainEntityOfPage: { '@id': `${baseUrl}/#home` },
    subjectOf: [
      { '@id': `${baseUrl}/#home` },
      { '@id': llmsDocumentId },
    ],
    additionalProperty: [
      ...includedFeatures.map((feature) => ({
        '@type': 'PropertyValue',
        name: 'Inbegrepen',
        value: feature,
      })),
      ...optionalFeatures.map((feature) => ({
        '@type': 'PropertyValue',
        name: 'Optioneel',
        value: feature,
      })),
    ],
    hasOfferCatalog: { '@id': offerCatalogId },
  },
  {
    '@type': 'OfferCatalog',
    '@id': offerCatalogId,
    name: 'Site in a Box facturatie',
    itemListElement: [
      { '@id': `${baseUrl}/#offer-yearly` },
      { '@id': `${baseUrl}/#offer-monthly` },
    ],
  },
  {
    '@type': 'Offer',
    '@id': `${baseUrl}/#offer-yearly`,
    name: 'Site in a Box - jaarbetaling',
    url: pricingUrl,
    price: 190,
    priceCurrency: 'EUR',
    priceSpecification: yearlyPriceSpecification(190),
    availability: 'https://schema.org/InStock',
    category: 'Website abonnement',
    description: 'Site in a Box voor €190 per jaar vooraf (ongeveer €16 per maand). Je bespaart €38 per jaar. Alle prijzen excl. btw.',
    additionalProperty: [
      {
        '@type': 'PropertyValue',
        name: 'Jaarbedrag',
        value: '€190 vooraf',
      },
      {
        '@type': 'PropertyValue',
        name: 'Besparing',
        value: '€38 per jaar ten opzichte van maandelijks',
      },
    ],
    itemOffered: { '@id': serviceId },
    offeredBy: { '@id': organizationId },
  },
  {
    '@type': 'Offer',
    '@id': `${baseUrl}/#offer-monthly`,
    name: 'Site in a Box - maandelijkse facturatie',
    url: pricingUrl,
    price: 19,
    priceCurrency: 'EUR',
    priceSpecification: monthlyPriceSpecification(19),
    availability: 'https://schema.org/InStock',
    category: 'Website abonnement',
    description: 'Site in a Box voor €19 per maand, maandelijks betaald en opzegbaar. Alle prijzen excl. btw.',
    additionalProperty: [
      {
        '@type': 'PropertyValue',
        name: 'Opzegbaarheid',
        value: 'Maandelijks opzegbaar',
      },
    ],
    itemOffered: { '@id': serviceId },
    offeredBy: { '@id': organizationId },
  },
  {
    '@type': 'DigitalDocument',
    '@id': llmsDocumentId,
    url: `${baseUrl}/llms.txt`,
    name: 'Site in a Box LLM context',
    encodingFormat: 'text/markdown',
    inLanguage: 'nl-NL',
    publisher: { '@id': organizationId },
    about: [
      { '@id': organizationId },
      { '@id': serviceId },
    ],
  },
  ...(hasFaq
    ? [
        {
          '@type': 'FAQPage',
          '@id': `${pageUrl}#faq`,
          url: `${pageUrl}#faq`,
          isPartOf: { '@id': pageId },
          inLanguage: 'nl-NL',
          publisher: { '@id': organizationId },
          mainEntity: faqItems.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: {
              '@type': 'Answer',
              text: f.a,
            },
          })),
        },
      ]
    : []),
];

const data = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

{!noindex && <script type="application/ld+json" set:html={JSON.stringify(data)} />}
