---
import { site } from '../../content/site';
import ThemeToggle from './ThemeToggle.astro';

const ctaSignup = '/intake';
const ctaLogin = 'mailto:info@siteinabox.nl?subject=Inloggen';
---

<header class="theme-main-menu menu-style-nine sticky-menu menu-overlay">
  <div class="inner-content gap-one">
    <div class="top-header position-relative">
      <div class="d-flex align-items-center">
        <div class="logo siab-logo order-lg-0 me-lg-5">
          <a href="/" aria-label="Site in a Box — naar homepage">
            <img src="/theme/images/logo/siab_logo.svg" alt="Site in a Box" />
          </a>
        </div>
        <div class="right-widget ms-auto order-lg-3">
          <ul class="d-flex align-items-center style-none">
            <li class="me-3">
              <ThemeToggle />
            </li>
            <li>
              <a href={ctaLogin} class="login-btn-one">Inloggen</a>
            </li>
            <li class="d-none d-md-inline-block ms-3">
              <a href={ctaSignup} class="btn-eighteen">Start gratis</a>
            </li>
          </ul>
        </div>
        <nav class="navbar navbar-expand-lg p0 order-lg-2 ms-lg-5 ms-3" aria-label="Hoofdnavigatie">
          <button
            class="navbar-toggler d-block d-lg-none"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
            aria-controls="navbarNav"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center">
              <li class="d-block d-lg-none">
                <div class="logo siab-logo">
                  <a href="/" aria-label="Site in a Box — naar homepage">
                    <img src="/theme/images/logo/siab_logo.svg" alt="Site in a Box" width="160" height="40" />
                  </a>
                </div>
              </li>
              {site.nav.map((item) => (
                <li class="nav-item">
                  <a class="nav-link" href={item.href}>{item.label}</a>
                </li>
              ))}
              <li class="d-md-none ps-3 pe-3 mt-20">
                <a href={ctaSignup} class="btn-eighteen w-100">Start gratis</a>
              </li>
            </ul>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>
