# Name of the external docker network that Nginx Proxy Manager
# attaches its containers to. Find it with:
#   docker network ls
# Look for the network NPM and any other proxied apps share.
# Common names: 'npm', 'proxy', 'nginx-proxy-manager_default'.
PROXY_NETWORK=npm

# CMS runtime (read by the SSR server)
CMS_DATA_DIR=/data
