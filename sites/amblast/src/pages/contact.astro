<p><label> Bericht<br /><span class="amb-form-field-wrap"><textarea cols="40" rows="10" maxlength="2000" class="amb-form-field amb-form-textarea" placeholder="Bericht" name="message"></textarea></span></label></p>
<input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
<p><input class="amb-form-field amb-form-submit has-spinner" type="submit" value="Verzenden" /></p>
<div class="amb-form-response" aria-hidden="true"></div>
</form>
