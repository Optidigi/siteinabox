<div class="amb-form-wrap no-js" lang="nl-NL" dir="ltr">
{useWeb3Forms ? (
<form action="https://api.web3forms.com/submit" method="POST" class="amb-form init" aria-label="Contactformulier" novalidate>
<input type="hidden" name="access_key" value={web3FormsKey} />
<input type="hidden" name="from_name" value={site.brand} />
<input type="hidden" name="subject" value={`Bericht via ${site.primaryDomain}`} />
<p><label><br /><span class="amb-form-field-wrap"><input required size="40" maxlength="400" class="amb-form-field amb-form-text amb-form-required" aria-required="true" type="text" name="name" placeholder="Naam*" value="" /></span></label></p>
<p><label><br /><span class="amb-form-field-wrap"><input required size="40" maxlength="400" class="amb-form-field amb-form-email amb-form-text amb-form-validates-email amb-form-required" aria-required="true" type="email" name="email" placeholder="Email*" value="" /></span></label></p>
<p><label><br /><span class="amb-form-field-wrap"><input required size="40" maxlength="400" class="amb-form-field amb-form-tel amb-form-text amb-form-required" aria-required="true" type="tel" name="phone" placeholder="Tel. nummer*" value="" /></span></label></p>
<p><label><br /><span class="amb-form-field-wrap"><textarea cols="40" rows="10" maxlength="2000" class="amb-form-field amb-form-textarea" placeholder="Omschrijving project" name="message"></textarea></span></label></p>
<input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
<p><input class="amb-form-field amb-form-submit has-spinner" type="submit" value="Verzenden" /></p>
<div class="amb-form-response" aria-hidden="true"></div>
</form>
) : (
