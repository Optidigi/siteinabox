    "github": {
      "purpose": "Read-only hosted repository, issue, pull-request, and Actions research.",
      "transport": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_READ_ONLY",
        "-e",
        "GITHUB_TOOLSETS",
        "ghcr.io/github/github-mcp-server@sha256:2b0c48b070f61e9d3969269ead600f62d00fb237b60ac849ef3d166ee7de9ad3",
        "stdio"
      ],
      "implementation": {
        "kind": "container",
        "identifier": "ghcr.io/github/github-mcp-server",
        "version": "1.6.0",
        "digest": "sha256:2b0c48b070f61e9d3969269ead600f62d00fb237b60ac849ef3d166ee7de9ad3"
      },
      "requiredEnv": ["GITHUB_PERSONAL_ACCESS_TOKEN"],
      "staticEnv": {
        "GITHUB_READ_ONLY": "1",
        "GITHUB_TOOLSETS": "repos,issues,pull_requests,actions"
      },
      "staticHeaders": {},
      "secretHeaders": {},
      "serverPolicy": {
        "readOnly": { "required": true, "enforcement": { "kind": "environment", "value": "GITHUB_READ_ONLY" } },
        "toolsets": {
          "required": true,
          "values": ["repos", "issues", "pull_requests", "actions"],
          "enforcement": { "kind": "environment", "value": "GITHUB_TOOLSETS" }
        },
        "toolAllowlist": { "required": false, "values": [], "enforcement": null }
      },
      "clientPolicy": {
        "defaultEnabled": true,
        "approval": { "required": false, "mode": "auto" },
        "enabledTools": { "required": false, "values": [] },
        "disabledTools": { "required": false, "values": [] }
      },
      "preconditions": ["A user-local token is optional; do not create one merely to start the server."],
      "projectionTargets": ["codex", "cursor"],
      "fallback": "Use git, gh read-only commands, or GitHub primary documentation."
    },
    "postgres": {
      "purpose": "Bounded read-only database inspection with a dedicated database role.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub@0.23.0", "--transport", "stdio", "--config", ".mcp/dbhub-postgres.toml"],
      "workingDirectory": "repositoryRoot",
      "implementation": {
        "kind": "npm",
        "identifier": "@bytebase/dbhub",
        "version": "0.23.0"
      },
      "requiredEnv": ["SIAB_MCP_POSTGRES_URL"],
      "staticEnv": {},
      "staticHeaders": {},
      "secretHeaders": {},
      "serverPolicy": {
        "readOnly": {
          "required": true,
          "enforcement": { "kind": "generatedConfig", "value": "tools.execute_sql.readonly" }
        },
        "toolsets": { "required": false, "values": [], "enforcement": null },
        "toolAllowlist": {
          "required": true,
          "values": ["execute_sql", "search_objects"],
          "enforcement": { "kind": "generatedConfig", "value": "tools" }
        }
      },
      "clientPolicy": {
        "defaultEnabled": false,
        "approval": { "required": false, "mode": "auto" },
        "enabledTools": { "required": false, "values": [] },
        "disabledTools": { "required": false, "values": [] }
      },
      "runtimeConfig": {
        "kind": "dbhub",
        "path": ".mcp/dbhub-postgres.toml",
        "source": {
          "id": "siab",
          "dsnEnv": "SIAB_MCP_POSTGRES_URL",
          "connectionTimeoutSeconds": 10,
          "queryTimeoutSeconds": 15
        },
        "executeSql": { "readOnly": true, "maxRows": 100 },
        "exposeSearchObjects": true
      },
      "preconditions": [
        "Keep disabled until an owner creates a dedicated siab_mcp_readonly role and user-local SIAB_MCP_POSTGRES_URL.",
        "The role must not be the Payload application role and must have only CONNECT, intended-schema USAGE, and intended-relation SELECT.",
        "Do not target production by default; database permissions remain the primary security boundary and do not reproduce application tenancy."
      ],
      "projectionTargets": ["codex"],
      "fallback": "Use approved psql read-only inspection with a dedicated database role."
    },
