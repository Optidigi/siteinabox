<div
  id="cookie-consent-banner"
  class="fixed inset-x-4 bottom-4 z-[80] hidden max-w-xl border p-4 shadow-2xl @min-[48rem]/site-frame:left-6 @min-[48rem]/site-frame:right-auto @min-[48rem]/site-frame:p-5"
  style="border-color: var(--cookie-consent-border, var(--color-border, rgb(226 232 240))); border-radius: var(--cookie-consent-radius, var(--radius-lg)); background: var(--cookie-consent-bg, var(--color-surface, #ffffff)); color: var(--cookie-consent-fg, var(--color-foreground, rgb(15 23 42))); font-family: var(--font-text);"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie preferences"
>
  <div class="space-y-4">
    <div class="space-y-2">
      <p class="text-[20px] font-semibold leading-tight" style="font-family: var(--font-heading); color: var(--cookie-consent-heading, currentColor);">Cookies</p>
      <p class="text-[14px] leading-[1.55]" style="color: var(--cookie-consent-muted, rgb(71 85 105));">
        We use necessary cookies for the site. With your consent, we measure anonymous site usage.
      </p>
    </div>
    <div class="flex flex-col gap-2 @min-[30rem]/site-frame:flex-row">
      <button
        type="button"
        class="px-4 py-2.5 text-[14px] font-medium transition-opacity hover:opacity-90"
        style="border-radius: var(--radius-md); background: var(--cookie-consent-action-bg, var(--color-brand)); color: var(--cookie-consent-action-fg, var(--color-brand-fg));"
        data-cookie-consent-accept
      >
        Accept
      </button>
      <button
        type="button"
        class="border px-4 py-2.5 text-[14px] font-medium transition-opacity hover:opacity-80"
        style="border-color: var(--cookie-consent-border, var(--color-border, rgb(226 232 240))); border-radius: var(--radius-md); background: var(--cookie-consent-secondary-bg, transparent); color: var(--cookie-consent-secondary-fg, currentColor);"
        data-cookie-consent-decline
      >
        Decline
      </button>
    </div>
  </div>
</div>

<button
  id="cookie-consent-preferences"
  type="button"
  class="fixed bottom-4 right-4 z-[70] hidden border px-3 py-2 text-[12px] font-medium shadow-lg transition-opacity hover:opacity-80"
  style="border-color: var(--cookie-consent-border, var(--color-border, rgb(226 232 240))); border-radius: var(--radius-md); background: var(--cookie-consent-bg, var(--color-surface, #ffffff)); color: var(--cookie-consent-muted, rgb(71 85 105)); font-family: var(--font-text);"
>
  Cookies
</button>

<script is:inline>
  (() => {
    const preferenceKey = "siab_cookie_consent_v1";
    const banner = document.getElementById("cookie-consent-banner");
    const preferences = document.getElementById("cookie-consent-preferences");
    if (!banner || !preferences) return;

    const readPreference = () => {
      try {
        return window.localStorage.getItem(preferenceKey);
      } catch {
        return null;
      }
    };

    const writePreference = (value) => {
      try {
        window.localStorage.setItem(preferenceKey, value);
      } catch {
        // If storage is blocked, keep the choice for the current page only.
      }
    };

    const showBanner = () => {
      banner.classList.remove("hidden");
      preferences.classList.add("hidden");
    };

    const hideBanner = () => {
      banner.classList.add("hidden");
      preferences.classList.remove("hidden");
    };

    const applyPreference = (value) => {
      if (value === "accepted") {
        window.SIABAnalytics?.grantConsent();
        hideBanner();
        return;
      }
      if (value === "declined") {
        window.SIABAnalytics?.revokeConsent();
        hideBanner();
        return;
      }
      showBanner();
    };

    banner.querySelector("[data-cookie-consent-accept]")?.addEventListener("click", () => {
      writePreference("accepted");
      applyPreference("accepted");
    });

    banner.querySelector("[data-cookie-consent-decline]")?.addEventListener("click", () => {
      writePreference("declined");
      applyPreference("declined");
    });

    preferences.addEventListener("click", showBanner);
    applyPreference(readPreference());
  })();
</script>
