{
  "name": "siab-site-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/build-cms-css.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "dev:cms-css": "node scripts/watch-cms-css.mjs",
    "check:responsive": "node scripts/check-responsive.mjs --mode=site",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.2",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1",
    "astro-seo": "^1.1.0",
    "lucide-preact": "^1.14.0",
    "posthog-js": "^1.382.0",
    "preact": "^10.29.1",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
