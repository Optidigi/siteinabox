{
  "name": "@siteinabox/site-renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "theme:generate": "tsx scripts/generate-theme-css.mjs",
    "test": "tsc --noEmit && tsx --test src/theme/*.test.mjs src/providers/shadcnui-blocks/*.test.mjs src/visual-parity/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "visual:provider-parity": "tsx src/visual-parity/shadcnui-blocks-visual-parity.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./seo": {
      "types": "./src/seo/index.ts",
      "import": "./src/seo/index.ts",
      "default": "./src/seo/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.tsx",
      "import": "./src/theme/index.tsx",
      "default": "./src/theme/index.tsx"
    },
    "./theme/resolve": {
      "types": "./src/theme/resolve.ts",
      "import": "./src/theme/resolve.ts",
      "default": "./src/theme/resolve.ts"
    },
    "./blocks/variants": {
      "types": "./src/blocks/variants.ts",
      "import": "./src/blocks/variants.ts",
      "default": "./src/blocks/variants.ts"
    },
    "./tenant-renderers/resolve": {
      "types": "./src/tenant-renderers/resolve.ts",
      "import": "./src/tenant-renderers/resolve.ts",
      "default": "./src/tenant-renderers/resolve.ts"
    },
    "./source-templates": {
      "types": "./src/source-templates/index.ts",
      "import": "./src/source-templates/index.ts",
      "default": "./src/source-templates/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "dependencies": {
    "@fontsource-variable/caveat": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/nunito": "5.2.7",
    "@number-flow/react": "^0.6.0",
    "@paper-design/shaders-react": "^0.0.71",
    "@radix-ui/react-visually-hidden": "^1.1.2",
    "@siteinabox/contracts": "workspace:*",
    "@siteinabox/ui": "workspace:*",
    "lucide-react": "^1.17.0",
    "motion": "^12.42.2",
    "radix-ui": "1.4.3",
    "recharts": "3.8.1"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "pixelmatch": "^7.1.0",
    "playwright": "1.61.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3"
  }
}
