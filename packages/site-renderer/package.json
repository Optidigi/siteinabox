{
  "name": "@siteinabox/site-renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./seo": {
      "types": "./src/seo/index.ts",
      "import": "./src/seo/index.ts",
      "default": "./src/seo/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.tsx",
      "import": "./src/theme/index.tsx",
      "default": "./src/theme/index.tsx"
    },
    "./styles.css": "./src/styles.css"
  },
  "dependencies": {
    "@siteinabox/contracts": "workspace:*",
    "@siteinabox/ui": "workspace:*",
    "lucide-react": "^1.17.0"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
