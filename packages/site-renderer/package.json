{
  "name": "@siteinabox/site-renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./seo": {
      "types": "./src/seo/index.ts",
      "import": "./src/seo/index.ts",
      "default": "./src/seo/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.tsx",
      "import": "./src/theme/index.tsx",
      "default": "./src/theme/index.tsx"
    },
    "./theme/css-vars": {
      "types": "./src/theme/css-vars.ts",
      "import": "./src/theme/css-vars.ts",
      "default": "./src/theme/css-vars.ts"
    },
    "./source-blocks": {
      "types": "./src/source-blocks/index.ts",
      "import": "./src/source-blocks/index.ts",
      "default": "./src/source-blocks/index.ts"
    },
    "./source-chrome": {
      "types": "./src/source-chrome/index.ts",
      "import": "./src/source-chrome/index.ts",
      "default": "./src/source-chrome/index.ts"
    },
    "./source-templates": {
      "types": "./src/source-templates/index.ts",
      "import": "./src/source-templates/index.ts",
      "default": "./src/source-templates/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./canvas.css": "./src/canvas.css"
  },
  "dependencies": {
    "@fontsource-variable/caveat": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@siteinabox/contracts": "workspace:*",
    "@siteinabox/ui": "workspace:*",
    "lucide-react": "^1.17.0"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "tsx": "^4.22.4",
    "typescript": "6.0.3"
  }
}
