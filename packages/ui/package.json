{
  "name": "@siteinabox/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./composites/*": {
      "types": "./src/composites/*.tsx",
      "default": "./src/composites/*.tsx"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./lib/csp-nonce": {
      "types": "./src/lib/csp-nonce.tsx",
      "default": "./src/lib/csp-nonce.tsx"
    },
    "./lib/csp-style": {
      "types": "./src/lib/csp-style.tsx",
      "default": "./src/lib/csp-style.tsx"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./providers/shadcnui-blocks/radix-nova": {
      "types": "./src/providers/shadcnui-blocks/radix-nova/index.ts",
      "default": "./src/providers/shadcnui-blocks/radix-nova/index.ts"
    },
    "./providers/shadcnui-blocks/radix-nova/tailwind.css": "./src/providers/shadcnui-blocks/radix-nova/tailwind.css",
    "./styles/shadcn.css": "./src/styles/shadcn.css"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.23.24",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "next-intl": "^4.13.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.77.0",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
