{
  "name": "siteinabox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=26.0.0 <27.0.0"
  },
  "scripts": {
    "audit:provider-cutover": "node scripts/check-generated-site-provider-cutover.mjs",
    "cms:cleanup-test-data": "node scripts/cleanup-cms-test-data.mjs",
    "cms:cleanup-test-data:test": "node --test scripts/cleanup-cms-test-data.test.mjs",
    "cms:typecheck": "pnpm --dir apps/cms typecheck",
    "cms:test": "pnpm --dir apps/cms test",
    "cms:build": "pnpm --dir apps/cms build",
    "contracts:typecheck": "pnpm --dir packages/contracts typecheck",
    "docs:check": "node scripts/check-doc-links.mjs",
    "frontend:verify": "pnpm packages:typecheck && pnpm --dir apps/cms lint:ui-boundary && pnpm --dir apps/cms lint:ui-composition && pnpm --dir apps/cms lint:no-css",
    "intake:build": "pnpm --filter siteinabox-intake build",
    "intake:test": "pnpm --filter siteinabox-intake test",
    "landing:build": "pnpm --filter siteinabox-landing build",
    "landing:test": "pnpm --filter siteinabox-landing test",
    "legal:check": "pnpm --dir packages/legal-content check",
    "mcp:check": "node --test scripts/sync-mcp-config.test.mjs && node scripts/sync-mcp-config.mjs --check",
    "mcp:sync": "node scripts/sync-mcp-config.mjs",
    "packages:typecheck": "pnpm contracts:typecheck && pnpm ui:typecheck && pnpm site-renderer:typecheck",
    "renderer:build": "pnpm --dir apps/renderer build",
    "renderer:deploy-contract": "node scripts/check-renderer-deploy-contract.mjs",
    "renderer:test": "pnpm --dir apps/renderer test",
    "renderer:typecheck": "pnpm --dir apps/renderer typecheck",
    "provider:visual-parity": "pnpm renderer:build && pnpm --dir packages/site-renderer visual:provider-parity",
    "site-renderer:typecheck": "pnpm --dir packages/site-renderer typecheck",
    "site:build": "pnpm landing:build",
    "site:test": "pnpm landing:test",
    "type-safety:check": "node --test scripts/check-type-safety.test.mjs && node scripts/check-type-safety.mjs",
    "type-safety:test": "node --test scripts/check-type-safety.test.mjs",
    "ui:typecheck": "pnpm --dir packages/ui typecheck"
  }
}
