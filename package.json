{
  "name": "siteinabox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "cms:typecheck": "pnpm --dir apps/cms --ignore-workspace typecheck",
    "cms:test": "pnpm --dir apps/cms --ignore-workspace test",
    "cms:build": "pnpm --dir apps/cms --ignore-workspace build",
    "contracts:typecheck": "pnpm --dir packages/contracts typecheck",
    "frontend:verify": "pnpm packages:typecheck && pnpm --dir apps/cms lint:ui-boundary && pnpm --dir apps/cms lint:ui-composition && pnpm --dir apps/cms lint:no-css",
    "intake:build": "pnpm --dir apps/intake --ignore-workspace build",
    "intake:test": "pnpm --dir apps/intake --ignore-workspace test",
    "landing:build": "pnpm --dir apps/landing --ignore-workspace build",
    "landing:test": "pnpm --dir apps/landing --ignore-workspace test",
    "packages:typecheck": "pnpm contracts:typecheck && pnpm ui:typecheck && pnpm site-renderer:typecheck",
    "renderer:build": "pnpm --dir apps/renderer build",
    "renderer:typecheck": "pnpm --dir apps/renderer typecheck",
    "site-renderer:typecheck": "pnpm --dir packages/site-renderer typecheck",
    "site:build": "pnpm landing:build",
    "site:test": "pnpm landing:test",
    "tenant:amicare:build": "pnpm --dir sites/ami-care --ignore-workspace build",
    "tenant:amicare:responsive": "pnpm --dir sites/ami-care --ignore-workspace check:responsive",
    "tenant:amblast:build": "pnpm --dir sites/amblast --ignore-workspace build",
    "template:build": "pnpm --dir packages/site-template --ignore-workspace build",
    "template:test": "pnpm --dir packages/site-template --ignore-workspace test",
    "ui:typecheck": "pnpm --dir packages/ui typecheck"
  }
}
